				<EmbeddedObject>
					<Id>1774862387846</Id>
					<Name><![CDATA[CombustionSink]]></Name>
					<X>1005</X><Y>320</Y>
					<Label><X>-20</X><Y>-18</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<ActiveObjectClass>
						<PackageName><![CDATA[com.anylogic.libraries.processmodeling]]></PackageName>
						<ClassName><![CDATA[Sink]]></ClassName>
					</ActiveObjectClass>
					<GenericParameterSubstitute>
						<GenericParameterSubstituteReference>
							<PackageName><![CDATA[com.anylogic.libraries.processmodeling]]></PackageName>
							<ClassName><![CDATA[Sink]]></ClassName>
							<ItemName><![CDATA[1412336242929]]></ItemName>
						</GenericParameterSubstituteReference>
					</GenericParameterSubstitute>
					<Parameters>
						<Parameter>
							<Name><![CDATA[onEnter]]></Name>
							<Value Class="CodeValue">
								<Code><![CDATA[// Log WasteBurned and finalize LCA for this combustion cycle
double cycleMass_t = WasteToBeBurned;
double cycleMass_kg = cycleMass_t * 1000.0;
WasteBurned += cycleMass_t;
WasteToBeBurned = 0.0;
// CE3.0 fix: apply emission factors (kg pollutant / kg waste) — lines were missing
totalCO2EmittedKg += cycleMass_kg * emissionFactor_CO2_kgPerKg;
totalCOEmittedKg  += cycleMass_kg * emissionFactor_CO_kgPerKg;
totalNOxEmittedKg += cycleMass_kg * emissionFactor_NOx_kgPerKg;
// Phase 10: per-stage LCA GWP (conservative: full mass at each stage — see thesis methodology)
double _gwpDry   = cycleMass_kg * gwpFactor_drying_kgCO2eqPerKg;
double _gwpTherm = cycleMass_kg * gwpFactor_thermalDecomp_kgCO2eqPerKg;
double _gwpSlag  = cycleMass_kg * gwpFactor_slagFormation_kgCO2eqPerKg;
GWPActualIncineration += _gwpDry + _gwpTherm + _gwpSlag;
// Phase 11: facility-level HTP, LUP, CED for incineration
double _htpInc = cycleMass_kg * htpFactor_incineration_CTUhPerKg;
double _lupInc = cycleMass_kg * lupFactor_incineration_m2yrPerKg;
double _cedInc = cycleMass_kg * cedFactor_incineration_MJPerKg;
// (stored as local for future facility-level HTP/LUP/CED accumulators — see Phase 12)
traceln(String.format("[COMBUSTION-LCA t=%.1fd] Δ GWP=%.2f | HTP=%.2e | LUP=%.4f | CED=%.2f",
    time(DAY), _gwpDry+_gwpTherm+_gwpSlag, _htpInc, _lupInc, _cedInc));
traceln(String.format("[COMBUSTION-COMPLETE] t=%.1f | cycle=%.2f t | total_burned=%.2f t | cumCO2=%.2f kg | cumCO=%.4f kg | cumNOx=%.4f kg",
    time(), cycleMass_t, WasteBurned, totalCO2EmittedKg, totalCOEmittedKg, totalNOxEmittedKg));
send("CombustionFinished", this);]]></Code>
							</Value>
						</Parameter>
						<Parameter>
							<Name><![CDATA[destroyEntity]]></Name>
						</Parameter>
					</Parameters>
					<ReplicationFlag>false</ReplicationFlag>
					<Replication Class="CodeValue">
						<Code><![CDATA[100]]></Code>
					</Replication>
