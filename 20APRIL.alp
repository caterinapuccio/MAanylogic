					</Points>
					<IconOffset>60.0</IconOffset>
					<Properties Source="9990000000012" Target="9990000000012" Trigger="arrival">
						<Action><![CDATA[// Jolly truck arrived at provider: load waste and return
isReturning = true;
lastPickupTime = time(DAY);
if (sourceProvider != null) {
    lastPayloadTonnes = ((Provider) sourceProvider).rawWaste;
}
traceln(String.format("[TRUCK%d-LOADED] t=%.2fd | jolly arrived at %s | payload=%.3ft → returning",
    truckIndex, time(DAY),
    (sourceProvider != null ? ((Provider)sourceProvider).companyName : "?"),
    lastPayloadTonnes));
]]></Action>
