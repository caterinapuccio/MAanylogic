			<Events>
				<Event>
					<Id>1772102698008</Id>
					<Name><![CDATA[calculateOPEX]]></Name>
					<X>1390</X><Y>1520</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Properties TriggerType="timeout" Mode="cyclic">
						<Timeout Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="TimeUnits"><![CDATA[DAY]]></Unit>
						</Timeout>
						<Rate Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="RateUnits"><![CDATA[PER_DAY]]></Unit>
						</Rate>
						<Id>1772102698006</Id>
						<OccurrenceAtTime>true</OccurrenceAtTime>
						<OccurrenceDate>1772179200000</OccurrenceDate>
						<OccurrenceTime Class="CodeUnitValue">
							<Code><![CDATA[0]]></Code>
							<Unit Class="TimeUnits"><![CDATA[DAY]]></Unit>
						</OccurrenceTime>
						<RecurrenceCode Class="CodeUnitValue">
							<Code><![CDATA[30]]></Code>
							<Unit Class="TimeUnits"><![CDATA[DAY]]></Unit>
						</RecurrenceCode>
						<Condition><![CDATA[true]]></Condition>
					</Properties>
					<Action><![CDATA[// CE3.0: Monthly OPEX — variable-cost model (pay for capacity actually used).
// xxx: OPEX of storage is calculated linear to waste volume processed because of
// labor, forklift fuel, and handling equipment (scales with throughput, not fixed capacity).
// NOTE: No realistic BIWASE-specific prices are available for these cost components.
// Current value: opexPerStorageUnitPerMonth = 2 SGD/(t·month) is ILLUSTRATIVE.
// For calibration: request from BIWASE or estimate from Vietnam industrial labor + fuel data.
// usedCapacity = sum of raw buffer (recyclingStoragePerMat) + processed stock
// (currentStockPerMat) across all 6 material types (incl. ORGANIC_WASTE index 5).
double usedCapacity = 0;
for (int _m = 0; _m < 6; _m++) {  // CE3.0 Phase 15: 6 materials incl. ORGANIC_WASTE[5]
    usedCapacity += intermediate.recyclingStoragePerMat[_m]
                  + intermediate.currentStockPerMat[_m];
}
double monthlyIntOpex = usedCapacity * opexPerStorageUnitPerMonth;
intermediate.intermediateOpex += monthlyIntOpex;
intermediate.financialBalance -= monthlyIntOpex;
intermediate.totalCosts       += monthlyIntOpex;
// totalOpex deprecated — OPEX is tracked exclusively via intermediate.totalCosts

// ── Sync slider-controlled tier capacities to Intermediate (monthly) ──────
if (ctrl_tier1Cap > 0) {
    for (int _m = 0; _m < MaterialType.values().length; _m++) {
        intermediate.tier1CapPerMat[_m] = ctrl_tier1Cap;
    }
}
if (ctrl_tier2Cap > 0) {
    intermediate.tier2SharedCapacity = ctrl_tier2Cap;
}]]></Action>
				</Event>
				<Event>
					<Id>1772103309237</Id>
					<Name><![CDATA[annualFinancialUpdate]]></Name>
					<X>1670</X><Y>1440</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Properties TriggerType="timeout" Mode="cyclic">
						<Timeout Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="TimeUnits"><![CDATA[DAY]]></Unit>
						</Timeout>
						<Rate Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="RateUnits"><![CDATA[PER_DAY]]></Unit>
						</Rate>
						<Id>1772103309235</Id>
						<OccurrenceAtTime>true</OccurrenceAtTime>
						<OccurrenceDate>1803628800000</OccurrenceDate>
						<OccurrenceTime Class="CodeUnitValue">
							<Code><![CDATA[0]]></Code>
							<Unit Class="TimeUnits"><![CDATA[DAY]]></Unit>
						</OccurrenceTime>
						<RecurrenceCode Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="TimeUnits"><![CDATA[YEAR]]></Unit>
						</RecurrenceCode>
						<Condition><![CDATA[true]]></Condition>
					</Properties>
					<Action><![CDATA[// ═══ CE 3.0 Annual Financial Update ═══════════════════════════════════════
// Firm-level deltas are computed FIRST (Sections 1-2), then network savings
// (Section 3) reads the fresh values. This fixes the 1-year lag bug.

// 1. FIRM LEVEL (Providers) — compute provider deltas
for (Provider prov : providers) {
    double provCurrentNet = prov.totalRevenues - prov.totalCosts;
    double provAnnualCF = provCurrentNet - prov.lastYearNetBalance;
    prov.entityNPV += provAnnualCF / pow(1 + discountRate, currentYear);
    prov.lastYearNetBalance = provCurrentNet;
    // Annual snapshot of IS delta variables (mirrors Receiver pattern)
    prov.deltaFinancial_IS_vs_noIS = prov.totalBaselineCostIS - prov.totalActualISPayment;
    prov.deltaGWP_IS_vs_noIS       = prov.GWPNoIS - prov.GWPActualTotal;
    prov.deltaHTP_IS_vs_noIS       = prov.HTPNoIS - prov.HTPActualProcess;
    prov.deltaLUP_IS_vs_noIS       = prov.LUPNoIS - prov.LUPActualProcess;
    prov.deltaCED_IS_vs_noIS       = prov.CEDNoIS - prov.CEDActualProcess;
}

// 2. FIRM LEVEL (Receivers) — compute receiver deltas
for (Receiver rec : receivers) {
    double recCurrentNet = rec.totalRevenues - rec.totalCosts;
    double recAnnualCF = recCurrentNet - rec.lastYearNetBalance;
    rec.entityNPV += recAnnualCF / pow(1 + discountRate, currentYear);
    rec.lastYearNetBalance = recCurrentNet;
    // Update cumulative IS delta variables (snapshot from accumulators)
    rec.deltaFinancial_IS_vs_noIS = rec.totalReceivedFromIS * (priceVirginPerMat[matIndex(rec.myMaterial)] - priceSecondaryPerMat[matIndex(rec.myMaterial)]); // per-material
    rec.deltaGWP_IS_vs_noIS = rec.GWPNoIS - (rec.GWPFromVirgin + rec.GWPFromResidueTransport);
    // NOTE (audit 2026-03-25): HTPFromVirgin accumulates both (a) virgin production HTP
    // and (b) landfill overflow HTP from rejected residue (Receiver lines 7031-7033).
    // This naming is misleading but mathematically correct: both terms correctly reduce
    // the IS benefit. Transport HTP/LUP/CED is NOT tracked (transport model outputs GWP only).
    // This is a documented model scope limitation — see thesis Methods section.
    rec.deltaHTP_IS_vs_noIS = rec.HTPNoIS - rec.HTPFromVirgin;
    rec.deltaLUP_IS_vs_noIS = rec.LUPNoIS - rec.LUPFromVirgin;
    rec.deltaCED_IS_vs_noIS = rec.CEDNoIS - rec.CEDFromVirgin;
}


// 3. NETWORK LEVEL — reads fresh deltas from sections 1+2 above
// IS Gross Savings = Provider disposal costs avoided + Receiver material substitution savings
// NOTE: No double-counting here. Receiver savings = qty*(priceVirgin - priceSecondary)
// and Intermediate revenues ≈ qty*priceSecondary are COMPLEMENTARY parts of the same
// virgin-substitution event. Together they equal qty*priceVirgin (total value displaced
// from external virgin markets). The formula is: network benefit = providerSavings
// + qty*priceVirgin - intermediateCosts, which is correct. See audit note 2026-03-25.
networkTotalCostSavingsIS = providers.stream().mapToDouble(p -> p.deltaFinancial_IS_vs_noIS).sum()
             + receivers.stream().mapToDouble(r -> r.totalReceivedFromIS * (priceVirginPerMat[matIndex(r.myMaterial)] - priceSecondaryPerMat[matIndex(r.myMaterial)])).sum(); // per-material
// Pre-compute Intermediate net operating result (reused in sections 1 and 3)
intermediate.netOperatingResult = intermediate.totalRevenues - intermediate.totalCosts;
// IS Net Position = Gross Savings + Intermediate net operating result
// `npv` = NETWORK WELFARE NPV (CBA metric, includes counterfactual savings) — kept for scenario analysis.
// IS investment KPIs use intermediate.entityNPV (actual cash flows) — see plotNPV chart.
// Thesis Methods must state: network welfare NPV ≠ IS investment NPV (both reported separately).
double currentNetBalance = networkTotalCostSavingsIS + intermediate.netOperatingResult;
networkTotalEconomicBenefitIS = currentNetBalance;  // persist as chartable variable
// FINANCIAL-2 revised: ROI = (intermediate actual net operating result − IS infra CAPEX) / IS infra CAPEX
// gain = intermediate.netOperatingResult = totalRevenues − totalCosts (OPEX already netted)
// Counterfactual savings (provider/receiver) excluded — only actual Intermediate cash flows
// ROI < 0 while IS infra CAPEX not yet recovered; crosses zero at economic payback year
// useIS=false: netOperatingResult ≈ −OPEX → ROI ≈ −(100% + OPEX/totalCapex)
ROI = totalCapex == 0 ? 0.0 : ((intermediate.netOperatingResult - totalCapex) / totalCapex) * 100.0;
double cashflowThisYear = currentNetBalance - lastYearNetBalance;
npv += cashflowThisYear / pow(1 + discountRate, currentYear);

// ── Diagnostic: always-visible annual summary ───────────────────────────
traceln(String.format(
    "[CE3] Year %.0f | Exchanged=%.1f t | ProvSavings=%.0f SGD | NetSavings=%.0f SGD | IntOp=%.0f SGD | NPV=%.0f SGD",
    currentYear, totalExchanged,
    providers.stream().mapToDouble(p -> p.totalBaselineCostIS - p.totalActualISPayment).sum(),
    networkTotalCostSavingsIS,
    intermediate.netOperatingResult,
    npv));

// 4. FIRM LEVEL (Intermediate)
// Apply annual fixed recycling OPEX (labor, maintenance, energy, insurance)
intermediate.financialBalance  -= intermediate.recyclingOpexAnnual;
intermediate.totalCosts        += intermediate.recyclingOpexAnnual;
intermediate.intermediateOpex  += intermediate.recyclingOpexAnnual;
// intermediate.netOperatingResult already set in section 1 above — recompute with new OPEX
intermediate.netOperatingResult = intermediate.totalRevenues - intermediate.totalCosts;
double intAnnualCF = intermediate.netOperatingResult - intermediate.lastYearNetBalance;
intermediate.entityNPV += intAnnualCF / pow(1 + discountRate, currentYear);
intermediate.lastYearNetBalance = intermediate.netOperatingResult;

// 5. SALVAGE VALUE at Year 10
if (currentYear == 10) {
    double salvageValue = totalCapex * salvageValuePercent;  // IS infra salvage (storage + recycling)
    double discountedSalvage = salvageValue / pow(1 + discountRate, 10);
    npv += discountedSalvage;                   // welfare NPV salvage
    intermediate.entityNPV += discountedSalvage;  // IS investment NPV salvage
    traceln("Year 10: Salvage " + String.format("%.2f", discountedSalvage) + " SGD added to npv + entityNPV.");
}

// 6. Compute network LCA savings (Provider IS-pathway delta + Receiver IS substitution delta)
networkTotalGWPBenefitIS = providers.stream().mapToDouble(p -> p.deltaGWP_IS_vs_noIS).sum()
    + receivers.stream().mapToDouble(r -> r.GWPNoIS - (r.GWPFromVirgin + r.GWPFromResidueTransport)).sum();
networkTotalHTPBenefitIS = providers.stream().mapToDouble(p -> p.deltaHTP_IS_vs_noIS).sum()
    + receivers.stream().mapToDouble(r -> r.HTPNoIS - r.HTPFromVirgin).sum();
networkTotalLUPBenefitIS = providers.stream().mapToDouble(p -> p.deltaLUP_IS_vs_noIS).sum()
    + receivers.stream().mapToDouble(r -> r.LUPNoIS - r.LUPFromVirgin).sum();
networkTotalCEDBenefitIS = providers.stream().mapToDouble(p -> p.deltaCED_IS_vs_noIS).sum()
    + receivers.stream().mapToDouble(r -> r.CEDNoIS - r.CEDFromVirgin).sum();

// 7. Time-series logging
timeLog.add(time());
npvLog.add(npv);
co2Log.add(networkTotalGWPBenefitIS);
HTPLog.add(networkTotalHTPBenefitIS);
LUPLog.add(networkTotalLUPBenefitIS);
CEDLog.add(networkTotalCEDBenefitIS);
exchangedLog.add(totalExchanged);
// CE3.0 audit 2026-03-25: CSV header is landfill_cost_SGD — log the sum of landfillCostPerMat[]
// (landfill EmbeddedObject removed in CE3.0 Phase 2; totalWasteReceived tracked in Intermediate)
landfillLog.add(java.util.Arrays.stream(landfillCostPerMat).sum());

// 8. PREPARE FOR NEXT YEAR
lastYearNetBalance = currentNetBalance;
currentYear++;

// Export combined validation + truck-log report at end of 10-year horizon
if (currentYear >= 10) {
    exportValidationReport();  // sheets: Summary, Errors, ConnMap, TripLog, TruckSummary
    traceln("[CE3] Validation report (incl. TripLog) exported at year " + currentYear);
}
]]></Action>
				</Event>
			</Events>
