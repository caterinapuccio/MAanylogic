			<Events>
				<Event>
					<Id>9901000000003</Id>
					<Name><![CDATA[truckRetryEvent]]></Name>
					<Description><![CDATA[Fires every 6 hours. If pendingWaste > 0 and a truck is available, dispatches the truck and clears pendingWaste. This implements the parallel truck-wait behavior: the main statechart keeps generating waste weekly; this event independently retries dispatch until a truck is free.]]></Description>
					<X>60</X><Y>750</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Properties TriggerType="timeout" Mode="cyclic">
						<Timeout Class="CodeUnitValue">
							<Code><![CDATA[0.25]]></Code>
							<Unit Class="TimeUnits"><![CDATA[DAY]]></Unit>
						</Timeout>
						<Rate Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="RateUnits"><![CDATA[PER_SECOND]]></Unit>
						</Rate>
						<Id>9901000000004</Id>
						<OccurrenceAtTime>false</OccurrenceAtTime>
						<OccurrenceDate>1772092800000</OccurrenceDate>
						<OccurrenceTime Class="CodeUnitValue">
							<Code><![CDATA[0.0]]></Code>
							<Unit Class="TimeUnits"><![CDATA[DAY]]></Unit>
						</OccurrenceTime>
						<RecurrenceCode Class="CodeUnitValue">
							<Code><![CDATA[0.25]]></Code>
							<Unit Class="TimeUnits"><![CDATA[DAY]]></Unit>
						</RecurrenceCode>
						<Condition><![CDATA[true]]></Condition>
					</Properties>
					<Action><![CDATA[// Retry truck dispatch for IS waste sitting at provider site waiting for truck.
// Main statechart runs independently every 7d; this event fires every 6h
// and retries dispatch whenever pendingWaste > 0.
if (pendingWaste > 0 && !isTransporting) {
    GarbageTruck truck = null;
    int pIdx = getIndex();
    if (pIdx >= 0 && pIdx < main.garbageTrucks.size()) {
        GarbageTruck dedicated = main.garbageTrucks.get(pIdx);
        if (!dedicated.busy) truck = dedicated;
    }
    if (truck == null) {
        for (GarbageTruck t : main.garbageTrucks) {
            if (t.isJolly && !t.busy) { truck = t; break; }
        }
    }
    if (truck != null) {
        // rawWaste is set to pendingWaste so transit entry reads the correct payload
        rawWaste       = pendingWaste;
        truck.targetLat      = providerLat;
        truck.targetLon      = providerLon;
        truck.sourceProvider = this;
        truck.isLandfillRun  = false; // IS trip: storage already reserved in Intermediate
        isTransporting       = true;
        pendingWaste         = 0.0;
        isTruckWaiting       = false;
        truck.dispatchPending = true;
        if (getIndex() == 0) {
            traceln(String.format("[PROV0-PENDING-DISPATCH] t=%.2fd | dispatched=%.3ft %s → truck%d",
                time(DAY), rawWaste, myMaterial, truck.truckIndex));
        }
    } else if (getIndex() == 0) {
        traceln(String.format("[PROV0-PENDING-WAIT] t=%.2fd | pending=%.3ft — no truck yet",
            time(DAY), pendingWaste));
    }
}]]></Action>
				</Event>
			</Events>
			<Functions>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[Color]]></ReturnType>
					<Id>1772077166997</Id>
					<Name><![CDATA[getMaterialColor]]></Name>
					<X>10</X><Y>470</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[if (myMaterial == MaterialType.PLASTIC_SCRAP) return blue;
else if (myMaterial == MaterialType.PAPER_WASTE) return saddleBrown;
else if (myMaterial == MaterialType.FERROUS_METAL) return gray;
else if (myMaterial == MaterialType.TEXTILE_WASTE) return orange;
else if (myMaterial == MaterialType.NON_FERROUS_METAL) return darkGreen;
else if (myMaterial == MaterialType.ORGANIC_WASTE) return new java.awt.Color(0.4f, 0.8f, 0.1f);
else return black;]]></Body>
				</Function>
			</Functions>
