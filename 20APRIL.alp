			<StatechartElements>
				<StatechartElement Class="State" ParentState="ROOT_NODE">
					<Id>9990000000011</Id>
					<Name><![CDATA[home]]></Name>
					<X>350</X><Y>140</Y>
					<Label><X>10</X><Y>10</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Properties Width="100" Height="30">
						<EntryAction><![CDATA[busy = false;
// DEBUG: lorry.setVisible(false); // commented out — keeping lorry always visible for GIS visibility test
isReturning = false;
// Capture landfill flag BEFORE it is cleared at step 3b
boolean _wasLandfill = isLandfillRun;

// ── 1. Capture provider info BEFORE clearing sourceProvider ──────────────
String _logProvName = "?";
String _logMaterial = "?";
int    _logProvIdx  = myProviderIndex;
if (sourceProvider != null) {
    Provider _sp = (Provider) sourceProvider;
    _logProvName = _sp.companyName;
    _logMaterial = _sp.myMaterial.toString();
    _logProvIdx  = _sp.getIndex();
} else if (myProviderIndex >= 0 && myProviderIndex < main.providers.size()) {
    Provider _sp = (Provider) main.providers.get(myProviderIndex);
    _logProvName = _sp.companyName;
    _logMaterial = _sp.myMaterial.toString();
}

// ── 2. Notify Provider and clear sourceProvider ──────────────────────────
if (sourceProvider != null) {
    Provider p = (Provider) sourceProvider;
    p.isTransporting = false;
    p.assignedTruckID = -1;
    sourceProvider = null;
}

// ── 3. Dedicated trucks return empty to provider site ────────────────────
// Guard: at t=0 providerLat/Lon are 0 (StartupCode not yet run). Skip moveTo
// to avoid truck moving toward the ocean; StartupCode section 6b calls jumpTo().
if (time() > 0 && !isJolly && myProviderIndex >= 0 && myProviderIndex < main.providers.size()) {
    setSpeed(main.truckVelocity_kmh / 3.6);
    if (truckIndex == 0) {
        // DEBUG: hardcoded scalar coords for truck0 GIS visibility test
        // To revert: delete this if-block and uncomment the two lines below
        moveTo(10.93169, 106.71506); // prov0 lat/lon; was: moveTo(home_p.providerLat, home_p.providerLon)
    } else {
        Provider home_p = (Provider) main.providers.get(myProviderIndex);
        moveTo(home_p.providerLat, home_p.providerLon);
    }
}

// ── 3b. Landfill run: notify Intermediate of waste delivery ─────────────
if (isLandfillRun) {
    if (lastPayloadTonnes > 0) {
        main.intermediate.receiveLandfillWaste(lastPayloadTonnes);
    }
    isLandfillRun = false;
}

// ── 4. Update trip counters ───────────────────────────────────────────────
// Guard: statechart initializes home at t=0 BEFORE StartupCode runs.
// At that moment truckIndex=0 (default) and myProviderIndex=-1 for ALL trucks.
// Only count and log REAL trips (time > 0).
if (time(DAY) > 0) {
    tripsCompleted++;
    totalMassCarried += lastPayloadTonnes;
    double transitDays = time(DAY) - lastPickupTime;
    main.truckLog.add(new Object[]{
        time(DAY),                                           // [0] SimDay
        truckIndex,                                          // [1] TruckID
        isJolly ? "jolly" : ("dedicated#" + myProviderIndex), // [2] Role
        _logProvIdx,                                         // [3] ProvIdx
        _logProvName,                                        // [4] ProviderName
        _logMaterial,                                        // [5] Material
        lastPayloadTonnes,                                   // [6] Payload_t
        tripsCompleted,                                      // [7] TripNum
        totalMassCarried,                                    // [8] CumulMass_t
        transitDays                                          // [9] TransitTime_d
    });
    if (main.debugMode || truckIndex == 0) {
        traceln(String.format("[TRUCK %d] HOME t=%.2fd | trip#%d | %.3ft %s from %s | cumul=%.3ft | transit=%.2fd",
            truckIndex, time(DAY), tripsCompleted, lastPayloadTonnes,
            _logMaterial, _logProvName, totalMassCarried, transitDays));
    }
    // ── Per-truck trip log entry ─────────────────────────────────────────────
    String _tripType = _wasLandfill ? "LANDFILL" : "IS-RECYCLE";
    myTripLog.add(String.format(
        "Day%7.1f | %-11s | From: %-30s | Mat: %-12s | %6.3f t | Transit: %.2f d",
        time(DAY), _tripType, _logProvName, _logMaterial, lastPayloadTonnes, transitDays));
}
lastPayloadTonnes = 0.0;]]></EntryAction>
						<FillColor/>
					</Properties>
				</StatechartElement>
				<StatechartElement Class="State" ParentState="ROOT_NODE">
					<Id>9990000000012</Id>
					<Name><![CDATA[transit]]></Name>
					<X>350</X><Y>240</Y>
					<Label><X>10</X><Y>10</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Properties Width="100" Height="30">
						<EntryAction><![CDATA[busy = true;
lorry.setVisible(true);
// isReturning managed by t_dispatch (→false) and t_loaded (→true). NOT reset here.
// CE3.0 movement logic:
//   dedicated        : provider → BIWASE (loaded, direct)
//   jolly outbound   : BIWASE → provider (empty, isReturning=false)
//   jolly return leg : provider → BIWASE (loaded, isReturning=true)
setSpeed(main.truckVelocity_kmh / 3.6);
if (!isJolly) {
    if (truckIndex == 0) {
        // DEBUG: hardcoded scalar coords for truck0 GIS visibility test
        // To revert: delete this if-block and restore the moveTo line below
        moveTo(10.93000, 106.72000); // BIWASE lat/lon; was: moveTo(main.intermediateLat, main.intermediateLon)
    } else {
        moveTo(main.intermediateLat, main.intermediateLon);  // dedicated: loaded to BIWASE
    }
} else if (!isReturning) {
    moveTo(targetLat, targetLon);                        // jolly outbound: to provider
} else {
    moveTo(main.intermediateLat, main.intermediateLon);  // jolly return: loaded to BIWASE
}
// Payload + pickup time for dedicated trucks (jolly sets these in t_loaded)
if (!isJolly) {
    lastPickupTime = time(DAY);
    if (sourceProvider != null) {
        lastPayloadTonnes = ((Provider) sourceProvider).rawWaste;
    }
}
if (main.debugMode || truckIndex == 0) {
    String leg = (!isJolly) ? "dedicated→BIWASE[loaded]"
                            : (isReturning ? "jolly-return→BIWASE[loaded]" : "jolly-outbound→provider[empty]");
    traceln(String.format("[TRUCK %d] TRANSIT-ENTRY t=%.2fd | %s | payload=%.3ft",
        truckIndex, time(DAY), leg, lastPayloadTonnes));
}
// ── Detailed loaded-leg diagnostics for truck0 (dedicated, first leg only) ──
if (truckIndex == 0 && !isJolly && sourceProvider != null) {
    Provider _sp0 = (Provider) sourceProvider;
    double _distKm   = main.haversineKm(_sp0.providerLat, _sp0.providerLon,
                                         main.intermediateLat, main.intermediateLon);
    double _speedMs  = 10.0;                 // VelocityCode=10 MPS; getSpeed() crashes without CarExtension
    double _speedKmH = _speedMs * 3.6;
    double _travelH  = (_speedMs > 0) ? (_distKm * 1000.0 / _speedMs) / 3600.0 : -1;
    double _travelD  = _travelH / 24.0;
    traceln(String.format(
        "[TRUCK0-LOADED-LEG] t=%.4fd | FROM %s (%.5f°N %.5f°E) TO BIWASE (%.5f°N %.5f°E)" +
        " | dist=%.3fkm | speed=%.4fm/s (%.2fkm/h) | est.travel=%.6fd (%.2fh) | payload=%.4ft",
        time(DAY),
        _sp0.companyName, _sp0.providerLat, _sp0.providerLon,
        main.intermediateLat, main.intermediateLon,
        _distKm, _speedMs, _speedKmH, _travelD, _travelH,
        lastPayloadTonnes));
}]]></EntryAction>
						<FillColor/>
					</Properties>
				</StatechartElement>
				<StatechartElement Class="EntryPoint" ParentState="ROOT_NODE">
					<Id>9990000000010</Id>
