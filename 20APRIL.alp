					<Properties Source="9990000000011" Target="9990000000012" Trigger="condition">
						<Action><![CDATA[dispatchPending = false;  // CE3.0: clear trigger immediately; set externally by acceptBooking/truckRetryEvent/NonIS_Disposal
isReturning = false;
if (truckIndex == 0) {
    traceln(String.format("[TRUCK0-DISPATCH] t=%.2fd | condition fired | provider=%s | rawWaste=%.3ft",
        time(DAY),
        (sourceProvider != null ? ((Provider)sourceProvider).companyName : "null"),
        (sourceProvider != null ? ((Provider)sourceProvider).rawWaste : 0.0)));
}
]]></Action>
						<Timeout Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="TimeUnits"><![CDATA[SECOND]]></Unit>
						</Timeout>
