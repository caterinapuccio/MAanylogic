				<EmbeddedObject>
					<Id>9983001004</Id>
					<Name><![CDATA[pwSink]]></Name>
					<Description><![CDATA[PROCESS WASTE DES — Step 4/4: Sink — LCA accounting trigger. On entity arrival, staged LCA impacts (pw_pending*) are applied to cumulative accumulators: GWPActualProcess, HTPActualProcess, LUPActualProcess, CEDActualProcess. All pw_pending* buffers and recyc_pending* arrays are reset. This is the ONLY step where numbers change — all prior steps are timing and visualization only.]]></Description>
					<X>650</X><Y>540</Y>
					<Label><X>-20</X><Y>-18</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<ActiveObjectClass>
						<PackageName><![CDATA[com.anylogic.libraries.processmodeling]]></PackageName>
						<ClassName><![CDATA[Sink]]></ClassName>
					</ActiveObjectClass>
					<GenericParameterSubstitute>
						<GenericParameterSubstituteReference>
							<PackageName><![CDATA[com.anylogic.libraries.processmodeling]]></PackageName>
							<ClassName><![CDATA[Sink]]></ClassName>
							<ItemName><![CDATA[1412336242929]]></ItemName>
						</GenericParameterSubstituteReference>
					</GenericParameterSubstitute>
					<Parameters>
						<Parameter>
							<Name><![CDATA[onEnter]]></Name>
							<Value Class="CodeValue">
								<Code><![CDATA[// Phase 10: Process waste landfill DES complete — apply staged LCA impact\nGWPActualProcess += pw_pendingGWP;\nHTPActualProcess += pw_pendingHTP;\nLUPActualProcess += pw_pendingLUP;\nCEDActualProcess += pw_pendingCED;\nGWPActualTotal    = GWPActualTransport + GWPActualProcess;\ntraceln(String.format(\"[LANDFILL-DES-COMPLETE t=%.1fd] %.3f t → landfill | ΔGWP=%.2f kg CO2-eq | cumGWP=%.2f kg CO2-eq\",\n    time(DAY), pw_pendingQty, pw_pendingGWP, GWPActualProcess));\n// Reset staging buffers\npw_pendingQty = 0.0; pw_pendingGWP = 0.0; pw_pendingHTP = 0.0; pw_pendingLUP = 0.0; pw_pendingCED = 0.0;\njava.util.Arrays.fill(recyc_pendingRaw, 0.0);\njava.util.Arrays.fill(recyc_pendingProcessWaste, 0.0);]]></Code>
							</Value>
						</Parameter>
						<Parameter>
							<Name><![CDATA[destroyEntity]]></Name>
						</Parameter>
					</Parameters>
					<ReplicationFlag>false</ReplicationFlag>
					<Replication Class="CodeValue">
						<Code><![CDATA[100]]></Code>
					</Replication>
					<CollectionType>ARRAY_LIST_BASED</CollectionType>
					<InitialLocationType>XYZ</InitialLocationType>
