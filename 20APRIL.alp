						<Parameter>
							<Name><![CDATA[onExit]]></Name>
							<Value Class="CodeValue">
								<Code><![CDATA[// Phase 14: Fly ash routed to hazardous secured landfill — apply LCA burden
// Fly ash concentrates heavy metals (Pb, Cd, Zn) and dioxins. HAZARDOUS — NOT usable for bricks.
double flyAshMass_kg = stagingAshCycleMass_t * main.flyAsh_massFraction * 1000.0;
// [ILLUSTRATIVE] LCA factor for hazardous fly ash landfill — replace with ecoinvent:
// "treatment of fly ash from municipal incineration, residual material landfill" (RoW or SE Asia)
double gwpFlyAsh_kgCO2eq = flyAshMass_kg * 0.005; // [ILLUSTRATIVE: ~5 g CO2-eq/kg fly ash, ecoinvent RoW]
GWPActualIncineration += gwpFlyAsh_kgCO2eq;
traceln(String.format("[FLY-ASH-LANDFILL t=%.1fd] flyAsh=%.3ft (%.1f kg) → hazardous landfill | GWP+=%.4f kg CO2-eq",
    time(DAY), stagingAshCycleMass_t * main.flyAsh_massFraction, flyAshMass_kg, gwpFlyAsh_kgCO2eq));]]></Code>
							</Value>
						</Parameter>
						<Parameter>
							<Name><![CDATA[onRemove]]></Name>
						</Parameter>
					</Parameters>
