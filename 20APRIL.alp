						</RecurrenceCode>
						<Condition><![CDATA[true]]></Condition>
					</Properties>
					<Action><![CDATA[// CE3.0: intentionally empty — this event exists solely to give GarbageTruck a periodic
// internal event so AnyLogic re-evaluates the t_dispatch condition (dispatchPending).
