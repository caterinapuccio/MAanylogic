				</EmbeddedObject>
				<EmbeddedObject>
					<Id>9991001003</Id>
					<Name><![CDATA[flyAshToLandfill]]></Name>
					<Description><![CDATA[COMBUSTION DES — Step 7/7: Fly ash to hazardous landfill (tri 0.5, 1, 2 h). Fly ash (flyAsh_massFraction=0.04 of cycle mass) is classified as hazardous waste — concentrates heavy metals (Pb, Cd, Zn) and dioxins from combustion. Routed to secured hazardous landfill (NOT the brick kiln). LCA factor: ecoinvent 'treatment of fly ash from municipal incineration, residual material landfill' [ILLUSTRATIVE — replace before submission]. Exit action adds fly ash LCA burden to GWPActualIncineration.]]></Description>
					<X>920</X><Y>310</Y>
					<Label><X>-30</X><Y>-18</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<ActiveObjectClass>
						<PackageName><![CDATA[com.anylogic.libraries.processmodeling]]></PackageName>
						<ClassName><![CDATA[Delay]]></ClassName>
					</ActiveObjectClass>
					<GenericParameterSubstitute>
						<GenericParameterSubstituteReference>
							<PackageName><![CDATA[com.anylogic.libraries.processmodeling]]></PackageName>
							<ClassName><![CDATA[Delay]]></ClassName>
							<ItemName><![CDATA[1412336242930]]></ItemName>
						</GenericParameterSubstituteReference>
					</GenericParameterSubstitute>
					<Parameters>
