					<Parameters>
						<Parameter>
							<Name><![CDATA[onEnter]]></Name>
							<Value Class="CodeValue">
								<Code><![CDATA[// Recycling DES visualization complete — accounting already done in recyclingProcessing()\nStringBuilder _sb = new StringBuilder();\n_sb.append(String.format(\"[RECYCL-BATCH t=%.1fd]\", time(DAY)));\nfor (int _m = 0; _m < 6; _m++)  // CE3.0: 6 = MaterialType enum size (hardcoded; .values() unsupported in nested agent) {\n    if (recyc_pendingRaw[_m] > 0) {\n        double _eff = main.conversionEffPerMat[_m];\n        _sb.append(String.format(\" | %s: raw=%.2ft conv=%.2ft pw=%.2ft\",\n            matNames[_m], recyc_pendingRaw[_m],\n            recyc_pendingRaw[_m]*_eff, recyc_pendingProcessWaste[_m]));\n    }\n}\ntraceln(_sb.toString());]]></Code>
							</Value>
						</Parameter>
						<Parameter>
							<Name><![CDATA[destroyEntity]]></Name>
						</Parameter>
					</Parameters>
					<ReplicationFlag>false</ReplicationFlag>
					<Replication Class="CodeValue">
						<Code><![CDATA[100]]></Code>
					</Replication>
					<CollectionType>ARRAY_LIST_BASED</CollectionType>
					<InitialLocationType>XYZ</InitialLocationType>
					<ColumnCode Class="CodeValue">
						<Code><![CDATA[0]]></Code>
					</ColumnCode>
					<RowCode Class="CodeValue">
						<Code><![CDATA[0]]></Code>
					</RowCode>
					<LocationNameCode Class="CodeValue">
						<Code><![CDATA[""]]></Code>
					</LocationNameCode>
