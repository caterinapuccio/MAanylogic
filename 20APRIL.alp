				</EmbeddedObject>
				<EmbeddedObject>
					<Id>9991001002</Id>
					<Name><![CDATA[brickProduction]]></Name>
					<Description><![CDATA[COMBUSTION DES — Step 6/7: Brick production (tri 2, 4, 8 h). Bottom ash + WW treatment sludge fired in tunnel kiln. ESCAR p.70: 100,000 bricks/day capacity. Only bottom ash fraction (bottomAsh_massFraction=0.25) enters here. Exit action: brickMass = stagingAshCycleMass_t * bottomAsh_massFraction * brickYield_tPerTAsh; revenue credited to brickRevenues and financialBalance. [xxx: brickYield and brickPrice are ILLUSTRATIVE — replace before submission]]]></Description>
					<X>835</X><Y>310</Y>
					<Label><X>-50</X><Y>64</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<ActiveObjectClass>
						<PackageName><![CDATA[com.anylogic.libraries.processmodeling]]></PackageName>
						<ClassName><![CDATA[Delay]]></ClassName>
					</ActiveObjectClass>
					<GenericParameterSubstitute>
						<GenericParameterSubstituteReference>
							<PackageName><![CDATA[com.anylogic.libraries.processmodeling]]></PackageName>
							<ClassName><![CDATA[Delay]]></ClassName>
							<ItemName><![CDATA[1412336242930]]></ItemName>
						</GenericParameterSubstituteReference>
					</GenericParameterSubstitute>
					<Parameters>
						<Parameter>
							<Name><![CDATA[type]]></Name>
						</Parameter>
						<Parameter>
							<Name><![CDATA[delayTime]]></Name>
							<Value Class="CodeUnitValue">
								<Code><![CDATA[triangular( 2, 4, 8 )]]></Code>
								<Unit Class="TimeUnits"><![CDATA[HOUR]]></Unit>
							</Value>
						</Parameter>
						<Parameter>
							<Name><![CDATA[capacity]]></Name>
						</Parameter>
						<Parameter>
							<Name><![CDATA[maximumCapacity]]></Name>
							<Value Class="CodeValue">
								<Code><![CDATA[true]]></Code>
							</Value>
						</Parameter>
						<Parameter>
							<Name><![CDATA[entityLocation]]></Name>
						</Parameter>
						<Parameter>
							<Name><![CDATA[pushProtocol]]></Name>
						</Parameter>
						<Parameter>
							<Name><![CDATA[restoreEntityLocationOnExit]]></Name>
						</Parameter>
						<Parameter>
							<Name><![CDATA[forceStatisticsCollection]]></Name>
						</Parameter>
						<Parameter>
							<Name><![CDATA[onEnter]]></Name>
						</Parameter>
						<Parameter>
							<Name><![CDATA[onAtExit]]></Name>
						</Parameter>
						<Parameter>
							<Name><![CDATA[onExit]]></Name>
							<Value Class="CodeValue">
								<Code><![CDATA[// Phase 14: Brick production complete — credit revenue to BIWASE
double bottomAshMass_t = stagingAshCycleMass_t * main.bottomAsh_massFraction;
double brickMass_t     = bottomAshMass_t * brickYield_tPerTAsh;
double revenue         = brickMass_t * brickPrice_SGD_t;
brickProduced_t   += brickMass_t;
brickRevenues     += revenue;
financialBalance  += revenue;   // positive: BIWASE earns from brick sales
entityNPV         += revenue / Math.pow(1.0 + main.discountRate, time(YEAR));
traceln(String.format("[BRICK-PROD t=%.1fd] bottomAsh=%.3ft → bricks=%.3ft | revenue=%.2f SGD | cumBrickRev=%.2f SGD",
    time(DAY), bottomAshMass_t, brickMass_t, revenue, brickRevenues));]]></Code>
							</Value>
						</Parameter>
						<Parameter>
							<Name><![CDATA[onRemove]]></Name>
						</Parameter>
					</Parameters>
					<ReplicationFlag>false</ReplicationFlag>
					<Replication Class="CodeValue">
						<Code><![CDATA[100]]></Code>
					</Replication>
