			<StatechartElements>
				<StatechartElement Class="State" ParentState="ROOT_NODE">
					<Id>9001000000001</Id>
					<Name><![CDATA[Idle]]></Name>
					<X>50</X><Y>80</Y>
					<Label><X>45</X><Y>20</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Properties Width="130" Height="40">
						<FillColor/>
					</Properties>
				</StatechartElement>
				<StatechartElement Class="State" ParentState="ROOT_NODE">
					<Id>9001000000002</Id>
					<Name><![CDATA[GeneratingWaste]]></Name>
					<X>50</X><Y>330</Y>
					<Label><X>10</X><Y>20</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Properties Width="170" Height="50">
						<EntryAction><![CDATA[// CE3.0: Generate this week's waste supply ──────────────────────────
rawWaste     = Math.max(avgSupplyFromExcel * 0.01,
                        normal(avgSupplyFromExcel, avgSupplyFromExcel * supplyVariability));
// Normal dist, CV=supplyVariability. Floor = 1% of avg supply so rawWaste is never 0
// (companies always generate some waste; zero-weeks would skip IS dispatch entirely).
currentSupply = rawWaste;
bookingAccepted = false;
myActivityLog.add(String.format("Day%7.1f | GENERATED  | %.3f t %s",
    time(DAY), rawWaste, myMaterial));
// IS scenario: attempt booking with Intermediate (synchronous)
if (getIndex() == 0) {
    traceln(String.format("[PROV0-GEN] t=%.2fd | rawWaste=%.3ft %s | useIS=%b",
        time(DAY), rawWaste, myMaterial, main.useIS));
}
if (main.useIS) {
    bookingAccepted = main.intermediate.acceptBooking(myMaterial, rawWaste, this);
}
if (getIndex() == 0 && main.useIS) {
    traceln(String.format("[PROV0-BOOKING-RESULT] t=%.2fd | bookingAccepted=%b",
        time(DAY), bookingAccepted));
}]]></EntryAction>
						<FillColor/>
					</Properties>
				</StatechartElement>
				<StatechartElement Class="State" ParentState="ROOT_NODE">
					<Id>9001000000003</Id>
					<Name><![CDATA[IS_Accepted]]></Name>
					<X>270</X><Y>510</Y>
					<Label><X>25</X><Y>40</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Properties Width="150" Height="70">
						<EntryAction><![CDATA[// IS PATH: Booking accepted → Intermediate picks up
// Broad traceln suppressed (fires for all 66 providers). Prov0 debug only:
if (getIndex() == 0) {
    traceln(String.format("[PROV0-IS-ACCEPTED] t=%.2fd | rawWaste=%.3ft %s",
        time(DAY), rawWaste, myMaterial));
}
int matIdx = main.matIndex(myMaterial);
double distInt = main.haversineKm(providerLat, providerLon,
                                  main.intermediateLat, main.intermediateLon);

// ── ACTUAL costs incurred by this IS transaction ──────────────────────────
// Collection transport (Intermediate bears cost and arranges pickup) is fully
// accounted for inside Intermediate.acceptBooking() — cost, GWP, and all
// network KPI increments are recorded there. DO NOT duplicate them here.
// GWPISTransportToIntermediate is retained for this Provider's own LCA tracking
// (GWPActualTransport / GWPActualTotal accumulators below).
double GWPISTransportToIntermediate = main.transportGWPCalc(rawWaste, distInt);
// Fix 2026-03-25: removed duplicate tCost block (was double-counting
// networkTotalTransportCostISProcesses, totalTransportCost, transportGWPISProcesses,
// totalTransportGWP, intermediate.totalCosts, intermediate.financialBalance,
// intermediate.GWPActualTransport, intermediate.GWPActualTotal).

// ── ACTUAL provider financial transfer for this IS exchange ─────────────
// pricePaidToProvider[matIdx]: >0 = Intermediate pays Provider (high-value)
//                              <0 = Provider pays Intermediate (low-value)
double providerPayment = rawWaste * main.pricePaidToProvider[matIdx];
this.financialBalance  += providerPayment;   // positive = received; negative = paid
if (providerPayment >= 0) {
    this.totalRevenues += providerPayment;
} else {
    this.totalCosts    -= providerPayment;   // record as cost (magnitude)
    main.intermediate.totalRevenues -= providerPayment;  // Intermediate receives payment
    main.intermediate.financialBalance -= providerPayment;
}
// Intermediate records payment-to-provider as its cost
if (providerPayment > 0) {
    main.intermediate.totalCosts += providerPayment;
    main.intermediate.financialBalance -= providerPayment;
}

// ── DELTA METRICS: IS path vs. landfill baseline ──────────────────────────
// deltaFinancial_IS_vs_noIS: what provider would have spent (landfill + transport)
//   minus what IS actually cost the provider (|pricePaidToProvider| if paying,
//   or zero net cost if receiving payment).
double kgWaste = rawWaste * 1000.0;
double landfillDistKm = main.haversineKm(providerLat, providerLon,
                                          main.intermediateLat, main.intermediateLon);
// Financial savings = what provider avoids paying − what IS actually costs them
double baselineCost   = rawWaste * main.costLandfillPerMat[matIdx]
                       + main.transportCostCalc(rawWaste, landfillDistKm);
double actualISCost   = (providerPayment < 0) ? -providerPayment : 0.0;  // only if provider pays
// Accumulate raw cost components — IS deltas computed annually (annualFinancialUpdate)
totalBaselineCostIS  += baselineCost;
totalActualISPayment += actualISCost;
// GWP baseline transport declared here — used by GWPNoIS accumulator below
double GWPBaselineTransportToLandfill = main.transportGWPCalc(rawWaste, landfillDistKm);

// ── GWP breakdown tracking (IS path) ──────────────────────────────────
// Actual IS path: waste is recycled at Intermediate → lower process GWP
GWPActualTransport += GWPISTransportToIntermediate;
GWPActualProcess   += kgWaste * main.GWPWasteToRecycling[matIdx];
GWPActualTotal     += GWPISTransportToIntermediate + kgWaste * main.GWPWasteToRecycling[matIdx];
// Baseline (no IS) (no-IS): same waste would go to landfill
double cfTransportGWP = GWPBaselineTransportToLandfill;  // reuse already-computed value
double cfProcessGWP   = kgWaste * main.GWPWasteToLandfill[matIdx];
GWPNoIS += cfTransportGWP + cfProcessGWP;
// HTP / LUP / CED breakdown (no transport factor — process only)
HTPActualProcess  += kgWaste * main.HTPWasteToRecycling[matIdx];
HTPNoIS += kgWaste * main.HTPWasteToLandfill[matIdx];
LUPActualProcess  += kgWaste * main.LUPWasteToRecycling[matIdx];
LUPNoIS += kgWaste * main.LUPWasteToLandfill[matIdx];
CEDActualProcess  += kgWaste * main.CEDWasteToRecycling[matIdx];
CEDNoIS += kgWaste * main.CEDWasteToLandfill[matIdx];
// ── Network exchange counter ───────────────────────────────────────────
main.totalExchanged += rawWaste;  // track total IS-exchanged material [tonnes]
// ── Truck dispatch is now handled by Intermediate.acceptBooking() ──────────
// (Intermediate dispatches a truck when it accepts the booking, at t=0 of each
//  weekly cycle. isTransporting and assignedTruckID are still set by the truck
//  via its sourceProvider reference when it arrives.)
// ── Provider-side dispatch tracking ─────────────────────────────────────────
truckDispatches++;
totalMassDispatched += rawWaste;
myActivityLog.add(String.format("Day%7.1f | IS-SENT    | %.3f t %s -> BIWASE",
    time(DAY), rawWaste, myMaterial));
if (main.debugMode) {
    traceln(String.format("[CE3] Provider %d (%s): IS dispatch #%d | %.3ft %s | cumulative: %.3ft",
        getIndex(), companyName, truckDispatches, rawWaste, myMaterial, totalMassDispatched));
}]]></EntryAction>
						<FillColor/>
					</Properties>
				</StatechartElement>
				<StatechartElement Class="State" ParentState="ROOT_NODE">
					<Id>9001000000004</Id>
					<Name><![CDATA[IS_Rejected]]></Name>
					<X>50</X><Y>510</Y>
					<Label><X>30</X><Y>40</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Properties Width="150" Height="70">
						<EntryAction><![CDATA[// IS_REJECTED: booking could not be accepted (Intermediate storage full).
// t_RejectedDone immediately routes to NonIS_Disposal, which handles all
// cost, GWP, and truck dispatch accounting. Nothing to compute here.
if (getIndex() == 0) {
    int _mIdxR = main.matIndex(myMaterial);
    double _t1freeR = Math.max(0.0, main.intermediate.tier1CapPerMat[_mIdxR]
                                  - main.intermediate.recyclingStoragePerMat[_mIdxR]);
    double _t2freeR = Math.max(0.0, main.intermediate.tier2SharedCapacity
                                  - main.intermediate.tier2UsedCapacity);
    traceln(String.format("[PROV0-IS-REJECTED] t=%.2fd | rawWaste=%.3ft | tier1Free=%.2ft tier2Free=%.2ft",
        time(DAY), rawWaste, _t1freeR, _t2freeR));
}]]></EntryAction>
						<FillColor/>
					</Properties>
				</StatechartElement>
				<StatechartElement Class="State" ParentState="ROOT_NODE">
					<Id>9001000000005</Id>
					<Name><![CDATA[NonIS_Disposal]]></Name>
					<X>-180</X><Y>510</Y>
					<Label><X>10</X><Y>35</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Properties Width="160" Height="70">
						<EntryAction><![CDATA[// NON-IS BASELINE: Provider → truck → Intermediate landfill buffer ──────
// Waste is physically collected by a truck, delivered to Intermediate,
// and accumulated in WasteToBeBurned for the weekly combustion DES cycle.
// LCA accounting for the transport leg is recorded here (provider-side);
// incineration emissions are recorded in Intermediate.combustionSlagEvent.
int matIdx = main.matIndex(myMaterial);
myActivityLog.add(String.format("Day%7.1f | NON-IS     | %.3f t %s -> LF/incin (fracs from noIS arrays)",
    time(DAY), rawWaste, myMaterial));
double distEoL = main.haversineKm(providerLat, providerLon,
                                   main.intermediateLat, main.intermediateLon);

// ── Financial: material-specific disposal cost (landfill share × costLandfill as proxy) ──────────────────────────
// noIS_landfillShare / noIS_incinerationShare per material (Consensus-validated 2026-04-02)
double noIS_lf_frac    = main.noIS_landfillShare[matIdx];      // fraction to landfill/open dump
double noIS_incin_frac = main.noIS_incinerationShare[matIdx];  // fraction to incineration/open burning
// Financial: landfill cost applied to the landfill+other fraction (incineration cost not parameterized yet)
double disposalCost = rawWaste * noIS_lf_frac * main.costLandfillPerMat[matIdx]
                    + rawWaste * noIS_incin_frac * main.costLandfillPerMat[matIdx]; // incineration ≈ landfill cost proxy
this.financialBalance            -= disposalCost;
this.totalCosts                  += disposalCost;
main.landfillCostPerMat[matIdx]  += disposalCost;
double GWPTransportToLandfill = main.transportGWPCalc(rawWaste, distEoL);
double tCost = main.transportCostCalc(rawWaste, distEoL);
main.transportGWPNonISProcesses                += GWPTransportToLandfill;
main.networkTotalTransportCostNonISProcesses   += tCost;
main.totalTransportGWP  += GWPTransportToLandfill;
main.totalTransportCost += tCost;
this.totalCosts         += tCost;
this.financialBalance   -= tCost;

// ── GWP breakdown tracking (no-IS baseline: all to landfill) ─────────────
double kgWasteN = rawWaste * 1000.0;
GWPActualTransport += GWPTransportToLandfill;
// Phase 10: non-IS waste goes to incineration — use 3-stage combustion GWP factors
double _gwpCombustion = main.intermediate.gwpFactor_drying_kgCO2eqPerKg
                      + main.intermediate.gwpFactor_thermalDecomp_kgCO2eqPerKg
                      + main.intermediate.gwpFactor_slagFormation_kgCO2eqPerKg;
GWPActualProcess   += kgWasteN * _gwpCombustion;
GWPActualTotal     += GWPTransportToLandfill + kgWasteN * _gwpCombustion;
GWPNoIS  += GWPTransportToLandfill + kgWasteN * _gwpCombustion;  // no-IS: actual = incineration
// Phase 11: non-IS waste → incineration — use combustion-specific HTP/LUP/CED factors
HTPActualProcess += kgWasteN * main.intermediate.htpFactor_incineration_CTUhPerKg;
HTPNoIS          += kgWasteN * main.intermediate.htpFactor_incineration_CTUhPerKg;
LUPActualProcess += kgWasteN * main.intermediate.lupFactor_incineration_m2yrPerKg;
LUPNoIS          += kgWasteN * main.intermediate.lupFactor_incineration_m2yrPerKg;
CEDActualProcess += kgWasteN * main.intermediate.cedFactor_incineration_MJPerKg;
CEDNoIS          += kgWasteN * main.intermediate.cedFactor_incineration_MJPerKg;

// ── Physical truck dispatch: Provider → Intermediate landfill buffer ──────
// Reuses same truck pool as IS path. Truck carries rawWaste t from this site
// to Intermediate; on arrival, GarbageTruck.home calls receiveLandfillWaste().
if (rawWaste > 0 && !isTransporting) {
    GarbageTruck truck = null;
    int pIdx = getIndex();
    if (pIdx >= 0 && pIdx < main.garbageTrucks.size()) {
        GarbageTruck dedicated = main.garbageTrucks.get(pIdx);
        if (!dedicated.busy) truck = dedicated;
    }
    if (truck == null) {
        for (GarbageTruck t : main.garbageTrucks) {
            if (t.isJolly && !t.busy) { truck = t; break; }
        }
    }
    if (truck != null) {
        truck.targetLat        = providerLat;
        truck.targetLon        = providerLon;
        truck.sourceProvider   = this;
        truck.isLandfillRun    = true;   // flag: deliver to landfill buffer, not recycling
        isTransporting         = true;
        truck.dispatchPending = true;
        if (getIndex() == 0 || truck.truckIndex == 0) {
            traceln(String.format(
                "[DISPATCH-NonIS] t=%.2fd | prov%d(%s) → truck%d(jolly=%b) | %.3ft %s → landfill",
                time(DAY), getIndex(), companyName, truck.truckIndex, truck.isJolly, rawWaste, myMaterial));
        }
    } else {
        // No truck available: add directly to Intermediate buffer (fallback, no transport delay)
        main.intermediate.receiveLandfillWaste(rawWaste);
        traceln(String.format(
            "[DISPATCH-NonIS-FALLBACK] t=%.2fd | prov%d no truck available — direct buffer add %.3ft %s",
            time(DAY), getIndex(), rawWaste, myMaterial));
    }
}]]></EntryAction>
						<FillColor/>
					</Properties>
				</StatechartElement>
