					<Text><![CDATA[null]]></Text>
					<TextCode><![CDATA["=== BIWASE STORAGE FILL (day " + String.format("%.0f", time(DAY)) + ") ===\n"
+ "─── TIER 1  (guaranteed per material) ───\n"
+ String.format(" PLASTIC : %6.2f / %5.1f t  (%3.0f%%)\n",
    recyclingStoragePerMat[0], tier1CapPerMat[0],
    tier1CapPerMat[0]>0 ? recyclingStoragePerMat[0]/tier1CapPerMat[0]*100 : 0.0)
+ String.format(" PAPER   : %6.2f / %5.1f t  (%3.0f%%)\n",
    recyclingStoragePerMat[1], tier1CapPerMat[1],
    tier1CapPerMat[1]>0 ? recyclingStoragePerMat[1]/tier1CapPerMat[1]*100 : 0.0)
+ String.format(" FERROUS : %6.2f / %5.1f t  (%3.0f%%)\n",
    recyclingStoragePerMat[2], tier1CapPerMat[2],
    tier1CapPerMat[2]>0 ? recyclingStoragePerMat[2]/tier1CapPerMat[2]*100 : 0.0)
+ String.format(" TEXTILE : %6.2f / %5.1f t  (%3.0f%%)\n",
    recyclingStoragePerMat[3], tier1CapPerMat[3],
    tier1CapPerMat[3]>0 ? recyclingStoragePerMat[3]/tier1CapPerMat[3]*100 : 0.0)
+ String.format(" NONFERR : %6.2f / %5.1f t  (%3.0f%%)\n",
    recyclingStoragePerMat[4], tier1CapPerMat[4],
    tier1CapPerMat[4]>0 ? recyclingStoragePerMat[4]/tier1CapPerMat[4]*100 : 0.0)
+ "─── TIER 2  (shared overflow) ───\n"
+ String.format(" Used    : %6.2f / %5.1f t  (%3.0f%%)\n",
    tier2UsedCapacity, tier2SharedCapacity,
    tier2SharedCapacity>0 ? tier2UsedCapacity/tier2SharedCapacity*100 : 0.0)
+ "─── PROCESSED STOCK (saleable, ready) ───\n"
+ String.format(" PLASTIC : %6.2f t   PAPER : %6.2f t\n",
    currentStockPerMat[0], currentStockPerMat[1])
+ String.format(" FERROUS : %6.2f t   TEXTILE: %6.2f t\n",
    currentStockPerMat[2], currentStockPerMat[3])
+ String.format(" NONFERR : %6.2f t\n", currentStockPerMat[4])]]></TextCode>
