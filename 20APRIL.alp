					<Properties Source="9990000000012" Target="9990000000011" Trigger="arrival">
						<Action><![CDATA[if (truckIndex == 0 || (isJolly && isReturning)) {
    traceln(String.format("[TRUCK%d-ARRIVED@BIWASE] t=%.4fd | payload=%.4ft | travel=%.6fd (%.3fh) | %s → home",
        truckIndex, time(DAY), lastPayloadTonnes,
        time(DAY) - lastPickupTime, (time(DAY) - lastPickupTime) * 24.0,
        isJolly ? "jolly-complete" : "dedicated-complete"));
}]]></Action>
