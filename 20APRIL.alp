				<EmbeddedObject>
					<Id>9983001002</Id>
					<Name><![CDATA[pwTransport]]></Name>
					<Description><![CDATA[PROCESS WASTE DES — Step 2/4: Transport delay (tri 1, 2, 4 h). Represents internal logistics at BIWASE: forklift movement of residue bins from the sorting/processing hall to the outbound truck bay (~100–300 m on-site). Duration is dominated by equipment availability, not road travel. This is NOT an external GarbageTruck trip.]]></Description>
					<X>480</X><Y>530</Y>
					<Label><X>-30</X><Y>64</Y></Label>
