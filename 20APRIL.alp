		<ActiveObjectClass>
			<Id>1773637505379</Id>
			<Name><![CDATA[GarbageTruck]]></Name>
			<StartupCode><![CDATA[truckIndex = getIndex();
// CE3.0 Phase 3: dedicated trucks (0-65) own their provider; jolly trucks (66-70) are shared pool
isJolly = (truckIndex >= 66);
myProviderIndex = isJolly ? -1 : truckIndex;
// All trucks start at BIWASE; Main startup will reposition dedicated trucks after providers are initialized
jumpTo(main.intermediateLat, main.intermediateLon);
// truckMarker circle stays visible on GIS; lorry icon only shows during transit
// DEBUG: lorry.setVisible(false); // commented out — keeping lorry always visible for GIS visibility test
// CE3.0: truckMarker oval shape not yet added to presentation — commented out until shape exists
// if (isJolly) {
//     truckMarker.setFillColor(new java.awt.Color(255, 140, 0)); // orange = jolly
// } else {
//     truckMarker.setFillColor(new java.awt.Color(30, 100, 220)); // blue = dedicated
// }]]></StartupCode>
