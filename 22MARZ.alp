						<EqualsExpression><![CDATA["Go"]]></EqualsExpression>
						<SatisfiesExpression><![CDATA[true]]></SatisfiesExpression>
					</Properties>	
				</StatechartElement>
				<StatechartElement Class="Transition" ParentState="ROOT_NODE">
					<Id>9990000000015</Id>
					<Name><![CDATA[t_loaded]]></Name>
					<X>450</X><Y>250</Y>
					<Label><X>70</X><Y>5</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Points>
						<Point><X>0</X><Y>0</Y></Point>
						<Point><X>60</X><Y>0</Y></Point>
						<Point><X>60</X><Y>10</Y></Point>
						<Point><X>0</X><Y>10</Y></Point>
					</Points>
					<IconOffset>60.0</IconOffset>
					<Properties Source="9990000000012" Target="9990000000012" Trigger="arrival">
						<Action><![CDATA[// Jolly truck arrived at provider: load waste and return
isReturning = true;
lastPickupTime = time(DAY);
if (sourceProvider != null) {
    lastPayloadTonnes = ((Provider) sourceProvider).rawWaste;
}
traceln(String.format("[TRUCK%d-LOADED] t=%.2fd | jolly arrived at %s | payload=%.3ft → returning",
    truckIndex, time(DAY),
    (sourceProvider != null ? ((Provider)sourceProvider).companyName : "?"),
    lastPayloadTonnes));
]]></Action>
							<Timeout Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
