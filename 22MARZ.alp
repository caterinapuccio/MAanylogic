				 	<EmbeddedIcon>false</EmbeddedIcon>				
					<Id>1773335603758</Id>
					<Name><![CDATA[button]]></Name>
					<X>255</X><Y>175</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>true</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>false</ShowLabel>
					<DrawMode>SHAPE_DRAW_2D3D</DrawMode>
					<BasicProperties Width="90" Height="20">
                        <EmbeddedIcon>false</EmbeddedIcon>	
						<TextColor>-16777216</TextColor>
						<Enabled>true</Enabled>
						<EnableExpression><![CDATA[getBestIteration() > 0]]></EnableExpression>
						<ActionCode><![CDATA[String s = "";
s += "priceVirgin\t" + "→ priceVirginPerMat[] (per-material)" + "\n";
s += "costLandfill\t" + "→ costLandfillPerMat[] (per-material)" + "\n";
s += "priceSecondary\t" + "→ priceSecondaryPerMat[] (per-material)" + "\n";
s += "investedStorageCapacity\t" + format( getBestParamValue( _oqvar_investedStorageCapacity ) ) + "\n";
s += "capexPerStorageUnit\t" + format( capexPerStorageUnit ) + "\n";
s += "opexPerStorageUnitPerMonth\t" + format( opexPerStorageUnitPerMonth ) + "\n";
s += "discountRate\t" + format( discountRate ) + "\n";
s += "scenarioSheet\t" + String.valueOf( scenarioSheet ) + "\n";
s += "capexCivilPerUnit\t" + format( capexCivilPerUnit ) + "\n";
s += "capexEquipmentPerUnit\t" + format( capexEquipmentPerUnit ) + "\n";
s += "capexSafetyPerUnit\t" + format( capexSafetyPerUnit ) + "\n";
s += "capexITPerUnit\t" + format( capexITPerUnit ) + "\n";
s += "opexEnergyPerUnitPerMonth\t" + format( opexEnergyPerUnitPerMonth ) + "\n";
s += "opexMaintenancePerUnitPerMonth\t" + format( opexMaintenancePerUnitPerMonth ) + "\n";
s += "opexLaborPerUnitPerMonth\t" + format( opexLaborPerUnitPerMonth ) + "\n";
s += "opexInsurancePerUnitPerMonth\t" + format( opexInsurancePerUnitPerMonth ) + "\n";
s += "opexCompliancePerUnitPerMonth\t" + format( opexCompliancePerUnitPerMonth ) + "\n";
s += "allocationFactor\t" + format( allocationFactor ) + "\n";
s += "co2PerKgVirgin\t" + format( co2PerKgVirgin ) + "\n";
s += "energyMJPerKgVirgin\t" + format( energyMJPerKgVirgin ) + "\n";
s += "waterM3PerKgVirgin\t" + format( waterM3PerKgVirgin ) + "\n";
s += "salvageValuePercent\t" + format( salvageValuePercent ) + "\n";
s += "useIS\t" + format( useIS ) + "\n";

copyToClipboard( s );]]></ActionCode>
					</BasicProperties>
