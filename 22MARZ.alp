			<Events>
				<Event>
					<Id>1772012193176</Id>
					<Name><![CDATA[demandEvent]]></Name>
					<X>70</X><Y>160</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Properties TriggerType="timeout" Mode="cyclic">
						<Timeout Class="CodeUnitValue">
							<Code><![CDATA[7]]></Code>
							<Unit Class="TimeUnits"><![CDATA[DAY]]></Unit>
						</Timeout>
						<Rate Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="RateUnits"><![CDATA[PER_WEEK]]></Unit>
						</Rate>
						<Id>1772012193174</Id>
						<OccurrenceAtTime>true</OccurrenceAtTime>
						<OccurrenceDate>1772092800000</OccurrenceDate>
						<OccurrenceTime Class="CodeUnitValue">
							<Code><![CDATA[0]]></Code>
							<Unit Class="TimeUnits"><![CDATA[DAY]]></Unit>
						</OccurrenceTime>
						<RecurrenceCode Class="CodeUnitValue">
							<Code><![CDATA[7]]></Code>
							<Unit Class="TimeUnits"><![CDATA[DAY]]></Unit>
						</RecurrenceCode>
						<Condition><![CDATA[true]]></Condition>
					</Properties>
					<Action><![CDATA[// CE3.0: Weekly demand cycle.
// calculateDemand() calls fulfillDemand() on Intermediate (IS path)
// then falls back to virgin purchase for any unmet demand.
calculateDemand();]]></Action>
				</Event>
			</Events>
			<Functions>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>VOID</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1772012073285</Id>
					<Name><![CDATA[calculateDemand]]></Name>
					<X>70</X><Y>120</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[// ═══ CE3.0 calculateDemand — demand/fulfillment/processing/residue cycle ═══
// Called every period (weekly, every 7 simulation days). Sequence:
//   1. Request IS fulfillment from Intermediate for this period's demand
//   2. Buy virgin for any portion Intermediate cannot supply
//   3. Run internal processing on IS-received material
//   4. Return processing residue to Intermediate (Receiver bears transport)
//   5. Draw next period's demand

int matIdx = main.matIndex(myMaterial);

// ── STEP 1: Request IS fulfillment ───────────────────────────────────────
double deliveredQty = 0.0;
if (this.currentDemand > 0 && main.useIS) {
    deliveredQty = main.intermediate.fulfillDemand(this, myMaterial, this.currentDemand);
}

// ── STEP 2: Virgin purchase for unmet demand ──────────────────────────────
double unmetDemand = this.currentDemand - deliveredQty;
if (unmetDemand > 0) {
    main.totalVirginMaterial += unmetDemand;
    double virginCost = unmetDemand * main.priceVirginPerMat[matIdx]; // per-material from Materials sheet col O
    this.totalCosts        += virginCost;
    this.financialBalance  -= virginCost;
    this.totalVirginPurchased += unmetDemand;
    // LCA: GWP burden of virgin material procurement (kg CO2-eq)
    this.GWPFromVirgin    += unmetDemand * 1000.0 * main.GWPVirginPerKg[matIdx];
    // HTP/LUP/CED from virgin purchase (actual + baseline (no IS) = same for unmet demand)
    this.HTPFromVirgin    += unmetDemand * 1000.0 * main.HTPVirginPerKg[matIdx];
    this.LUPFromVirgin    += unmetDemand * 1000.0 * main.LUPVirginPerKg[matIdx];
    this.CEDFromVirgin    += unmetDemand * 1000.0 * main.CEDVirginPerKg[matIdx];
    // Baseline (no IS): unmet demand is virgin in both IS and no-IS scenarios
    this.GWPNoIS += unmetDemand * 1000.0 * main.GWPVirginPerKg[matIdx];
    this.HTPNoIS += unmetDemand * 1000.0 * main.HTPVirginPerKg[matIdx];
    this.LUPNoIS += unmetDemand * 1000.0 * main.LUPVirginPerKg[matIdx];
    this.CEDNoIS += unmetDemand * 1000.0 * main.CEDVirginPerKg[matIdx];
    if (main.debugMode) traceln(this + " [VIRGIN] " + String.format("%.2f", unmetDemand) + " t at " + String.format("%.2f", main.priceVirginPerMat[matIdx]) + " SGD/t = " + String.format("%.2f", virginCost) + " SGD");
}

// ── STEP 3: Pay Intermediate for IS-delivered material ────────────────────
// (Revenue is recorded on Intermediate side inside fulfillDemand().
//  Here the Receiver records the corresponding cost.)
if (deliveredQty > 0) {
    double secondaryCost = deliveredQty * main.priceSecondaryPerMat[matIdx]; // per-material from Materials col P
    this.totalCosts        += secondaryCost;
    this.financialBalance  -= secondaryCost;
    this.totalReceivedFromIS += deliveredQty;
    // Baseline (no IS): if no IS, this qty would have been bought as virgin
    this.GWPNoIS += deliveredQty * 1000.0 * main.GWPVirginPerKg[matIdx];
    this.HTPNoIS += deliveredQty * 1000.0 * main.HTPVirginPerKg[matIdx];
    this.LUPNoIS += deliveredQty * 1000.0 * main.LUPVirginPerKg[matIdx];
    this.CEDNoIS += deliveredQty * 1000.0 * main.CEDVirginPerKg[matIdx];
    if (main.debugMode) traceln(this + " [IS] " + String.format("%.2f", deliveredQty) + " t at " + String.format("%.2f", main.priceSecondaryPerMat[matIdx]) + " SGD/t = " + String.format("%.2f", secondaryCost) + " SGD");
}

// ── STEP 4: Internal processing & residue return ─────────────────────────
// Only IS-received material is processed (virgin is consumed directly;
// its downstream embodied impact is not modelled further in this scope).
// Processing efficiency → product (out of thesis scope) + residue to Intermediate.
if (deliveredQty > 0) {
    double residueQty = deliveredQty * (1.0 - processingEfficiency);
    if (residueQty > 0) {
        // Receiver arranges and pays for residue transport to Intermediate
        double distKm = main.haversineKm(receiverLat, receiverLon,
                                         main.intermediateLat, main.intermediateLon);
        double tCost  = main.transportCostCalc(residueQty, distKm);
        double GWPISTransportToIntermediate   = main.transportGWPCalc(residueQty, distKm);
        this.totalCosts              += tCost;
        this.financialBalance        -= tCost;
        this.GWPFromResidueTransport += GWPISTransportToIntermediate;
        main.networkTotalTransportCostISProcesses += tCost;
        main.transportGWPISProcesses  += GWPISTransportToIntermediate;
        main.totalTransportCost      += tCost;
        main.totalTransportGWP       += GWPISTransportToIntermediate;
        // Submit residue to Intermediate storage (coordinate-based; no Provider ref)
        boolean residueAccepted = main.intermediate.acceptResidue(myMaterial, residueQty, receiverLat, receiverLon);
        if (residueAccepted) {
            this.totalResidueSentBack += residueQty;
            if (main.debugMode) traceln(this + " [RESIDUE] " + String.format("%.2f", residueQty) + " t accepted by Intermediate, tCost=" + String.format("%.2f", tCost) + " SGD");
        } else {
            // Intermediate storage full: residue goes to landfill at receiver's site.
            // Transport cost was already charged above (Receiver paid to haul to Intermediate).
            // Now also charge: disposal fee + additional transport from Intermediate to EoL.
            // matIdxR removed 2026-03-25 audit — matIdx (line 6935) is identical; using matIdx below
            double disposalFee = residueQty * main.costLandfillPerMat[matIdx];
            this.totalCosts       += disposalFee;
            this.financialBalance -= disposalFee;
            double distToEoL = main.haversineKm(main.intermediateLat, main.intermediateLon,
                                                 main.intermediateLat, main.intermediateLon);
            double eoLtCost = main.transportCostCalc(residueQty, distToEoL);
            double eoLtGWP  = main.transportGWPCalc(residueQty, distToEoL);
            this.totalCosts              += eoLtCost;
            this.financialBalance        -= eoLtCost;
            this.GWPFromResidueTransport += eoLtGWP;
            main.networkTotalTransportCostISProcesses += eoLtCost;
            main.transportGWPISProcesses  += eoLtGWP;
            main.intermediate.totalWasteReceived += residueQty;
            main.landfillCostPerMat[matIdx] += disposalFee;
            this.totalResidueToEoL += residueQty;
            // LCA: process impact of landfill disposal for overflow residue
            double GWPResLandfill = residueQty * 1000.0 * main.GWPWasteToLandfill[matIdx];
            double HTPResLandfill = residueQty * 1000.0 * main.HTPWasteToLandfill[matIdx];
            double LUPResLandfill = residueQty * 1000.0 * main.LUPWasteToLandfill[matIdx];
            double CEDResLandfill = residueQty * 1000.0 * main.CEDWasteToLandfill[matIdx];
            this.GWPFromResidueTransport += GWPResLandfill;
            this.HTPFromVirgin           += HTPResLandfill; // residue landfill burden (IS actual path)
            this.LUPFromVirgin           += LUPResLandfill;
            this.CEDFromVirgin           += CEDResLandfill;
            if (main.debugMode) traceln(this + " [RESIDUE-OVERFLOW] " + String.format("%.2f", residueQty) + " t → landfill (Intermediate full).");
        }
    }
}

// ── STEP 5: Draw next period's demand ────────────────────────────────────
// Demand drawn from per-receiver Excel value (col G) with normal distribution
// coefficient of variation = demandVariability (col H, default 0.20 = 20%)
this.currentDemand = max(0.0, normal(avgDemandFromExcel, avgDemandFromExcel * demandVariability));
if (main.debugMode) traceln(this + " next demand: " + String.format("%.2f", this.currentDemand) + " t " + myMaterial);]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[Color]]></ReturnType>
					<Id>1772077204596</Id>
					<Name><![CDATA[getMaterialColor]]></Name>
					<X>70</X><Y>380</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[if (myMaterial == MaterialType.PLASTIC_SCRAP) return blue;
else if (myMaterial == MaterialType.PAPER_WASTE) return saddleBrown;
else if (myMaterial == MaterialType.FERROUS_METAL) return gray;
else if (myMaterial == MaterialType.TEXTILE_WASTE) return orange;
else if (myMaterial == MaterialType.NON_FERROUS_METAL) return darkGreen;
else return black;]]></Body>
				</Function>
			</Functions>
