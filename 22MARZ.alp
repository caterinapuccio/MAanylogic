			<Functions>
				<Function AccessType="public" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[boolean]]></ReturnType>
					<Id>8800000300200</Id>
					<Name><![CDATA[acceptBooking]]></Name>
					<Description><![CDATA[Evaluate if Intermediate can accept waste from a Provider. 2-tier storage: Tier 1 = guaranteed per-material slots, Tier 2 = shared flexible pool.
function updates storage counters and returns a boolean.]]></Description>
					<X>60</X><Y>800</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Parameter>
						<Name><![CDATA[mat]]></Name>
						<Type><![CDATA[MaterialType]]></Type>
					</Parameter>
					<Parameter>
						<Name><![CDATA[qty]]></Name>
						<Type><![CDATA[double]]></Type>
					</Parameter>
					<Parameter>
						<Name><![CDATA[prov]]></Name>
						<Type><![CDATA[Provider]]></Type>
					</Parameter>
					<Body><![CDATA[// Guard: do not dispatch a truck for zero-quantity bookings (rawWaste clamped to 0)
if (qty <= 0.0) return false;

// ═══ CE3.0: acceptBooking — 2-tier storage + booking log ════════════════════
int matIdx = main.matIndex(mat);

// Distance from this provider to Intermediate (for transport metrics)
double distKm = main.haversineKm(prov.providerLat, prov.providerLon,
                                  intermediateLat, intermediateLon);

// Increment received counter
totalBookingsReceived[matIdx]++;

// Check Tier 1: guaranteed capacity for this material
double tier1Free = tier1CapPerMat[matIdx] - recyclingStoragePerMat[matIdx]; // Tier 1 = raw waste buffer only; currentStockPerMat is Tier 2 processed stock (separate pool)
if (tier1Free < 0) tier1Free = 0;

if (qty <= tier1Free) {
    // ── ACCEPTED: fits entirely in Tier 1 ───────────────────────────────────
    recyclingStoragePerMat[matIdx] += qty;
    totalBookingsAccepted[matIdx]++;
    double tCost = main.transportCostCalc(qty, distKm);
double gwpCollection = main.transportGWPCalc(qty, distKm);
    this.totalCosts            += tCost;
    this.financialBalance      -= tCost;
    main.networkTotalTransportCostISProcesses += tCost;
    main.totalTransportCost    += tCost;
    main.transportGWPISProcesses += gwpCollection;
    main.totalTransportGWP     += gwpCollection;
        bookingLog.add(new Object[]{
        time(),                        // simulation day of request
        prov.getIndex(),               // provider index (0-65)
        mat.toString(),                // material type
        qty,                           // amount requested (t)
        "ACCEPTED",                    // outcome
        "Tier1",                       // storage tier used
        distKm,                        // distance to intermediate (km)
        tCost                          // transport cost charged to intermediate (SGD)
    });
    // CE3.0 Phase 3: dispatch — dedicated truck first, fall back to jolly pool
    {
        GarbageTruck truck = null;
        int pIdx = prov.getIndex();
        if (pIdx >= 0 && pIdx < main.garbageTrucks.size()) {
            GarbageTruck dedicated = main.garbageTrucks.get(pIdx);
            if (!dedicated.busy) truck = dedicated;
        }
        if (truck == null) {
            for (GarbageTruck t : main.garbageTrucks) {
                if (t.isJolly && !t.busy) { truck = t; break; }
            }
        }
        if (truck != null) {
            truck.targetLat = prov.providerLat;
            truck.targetLon = prov.providerLon;
            truck.sourceProvider = prov;
            prov.isTransporting = true;  // CE3.0 Phase 3: guard against double-booking
            send("Go", truck);
            if (prov.getIndex() == 0 || truck.truckIndex == 0) {
                traceln(String.format("[DISPATCH-T1] t=%.2fd | prov%d(%s) → truck%d(jolly=%b) | %.3ft %s",
                    time(DAY), prov.getIndex(), prov.companyName, truck.truckIndex, truck.isJolly, qty, mat));
            }
        } else if (prov.getIndex() == 0) {
            traceln(String.format("[DISPATCH-FAIL-T1] t=%.2fd | prov0 → no truck available | %.3ft %s",
                time(DAY), qty, mat));
        }
    }
    return true;
}

// Check Tier 2: shared flexible pool
double tier2Free = tier2SharedCapacity - tier2UsedCapacity;
double neededFromTier2 = qty - tier1Free;

if (neededFromTier2 <= tier2Free) {
    // ── ACCEPTED: split between Tier 1 and Tier 2 ───────────────────────────────────────
    recyclingStoragePerMat[matIdx] += qty;
    tier2UsedCapacity += neededFromTier2;
    totalBookingsAccepted[matIdx]++;
    double tCost = main.transportCostCalc(qty, distKm);
double gwpCollection = main.transportGWPCalc(qty, distKm);
    this.totalCosts            += tCost;
    this.financialBalance      -= tCost;
    main.networkTotalTransportCostISProcesses += tCost;
    main.totalTransportCost    += tCost;
    main.transportGWPISProcesses += gwpCollection;
    main.totalTransportGWP     += gwpCollection;
        bookingLog.add(new Object[]{
        time(),
        prov.getIndex(),
        mat.toString(),
        qty,
        "ACCEPTED",
        String.format("Tier1+%.2ft_Tier2", neededFromTier2),
        distKm,
        tCost
    });
    // CE3.0 Phase 3: dispatch — dedicated truck first, fall back to jolly pool
    {
        GarbageTruck truck = null;
        int pIdx = prov.getIndex();
        if (pIdx >= 0 && pIdx < main.garbageTrucks.size()) {
            GarbageTruck dedicated = main.garbageTrucks.get(pIdx);
            if (!dedicated.busy) truck = dedicated;
        }
        if (truck == null) {
            for (GarbageTruck t : main.garbageTrucks) {
                if (t.isJolly && !t.busy) { truck = t; break; }
            }
        }
        if (truck != null) {
            truck.targetLat = prov.providerLat;
            truck.targetLon = prov.providerLon;
            truck.sourceProvider = prov;
            prov.isTransporting = true;  // CE3.0 Phase 3: guard against double-booking
            send("Go", truck);
            if (prov.getIndex() == 0 || truck.truckIndex == 0) {
                traceln(String.format("[DISPATCH-T2] t=%.2fd | prov%d(%s) → truck%d(jolly=%b) | %.3ft %s",
                    time(DAY), prov.getIndex(), prov.companyName, truck.truckIndex, truck.isJolly, qty, mat));
            }
        } else if (prov.getIndex() == 0) {
            traceln(String.format("[DISPATCH-FAIL-T2] t=%.2fd | prov0 → no truck available | %.3ft %s",
                time(DAY), qty, mat));
        }
    }
    return true;
}

// ── REJECTED: storage capacity exhausted ────────────────────────────────────
totalBookingsRejected[matIdx]++;
bookingLog.add(new Object[]{
    time(),
    prov.getIndex(),
    mat.toString(),
    qty,
    "REJECTED",
    String.format("Tier1Free=%.2ft_Tier2Free=%.2ft", tier1Free, tier2Free),
    distKm,
    0.0        // no transport cost — Provider self-hauls to landfill
});
return false;]]></Body>
				</Function>
				<Function AccessType="public" StaticFunction="false">
					<ReturnModificator>VOID</ReturnModificator>
					<ReturnType><![CDATA[void]]></ReturnType>
					<Id>8800000300201</Id>
					<Name><![CDATA[recyclingProcessing]]></Name>
					<Description><![CDATA[Monthly processing: apply conversionEfficiency per material to convert raw waste buffer into recycled stock. Process waste goes to EndOfLife.]]></Description>
					<X>60</X><Y>850</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[int nMat = MaterialType.values().length;
for (int m = 0; m < nMat; m++) {
    double rawBuffer = recyclingStoragePerMat[m];
    if (rawBuffer <= 0) continue;

    double convEff = main.conversionEffPerMat[m];
    double converted = rawBuffer * convEff;
    double processWaste = rawBuffer * (1.0 - convEff);

    // Add converted material to saleable stock
    currentStockPerMat[m] += converted;

    // Process waste → EndOfLife
    if (processWaste > 0) {
        double pwCost = processWaste * main.costLandfillPerMat[m];
        main.intermediate.totalWasteReceived += processWaste;
        this.financialBalance -= pwCost;
        this.totalCosts += pwCost;
        main.landfillCostPerMat[m] += pwCost;

        // Transport to EndOfLife
        double distEoL = main.haversineKm(this.intermediateLat, this.intermediateLon, main.intermediateLat, main.intermediateLon);
        double GWPISTransportToIntermediate = main.transportGWPCalc(processWaste, distEoL);
        double tCost = main.transportCostCalc(processWaste, distEoL);
        main.transportGWPISProcesses  += GWPISTransportToIntermediate;
        main.networkTotalTransportCostISProcesses += tCost;
        main.totalTransportGWP += GWPISTransportToIntermediate;
        main.totalTransportCost += tCost;
        this.totalCosts += tCost;
        this.financialBalance -= tCost;
    }

    // ── LCA tracking: recycling process impact ──────────────────────────
    double kgConverted = converted * 1000.0;
    double kgProcWaste = processWaste * 1000.0;
    // Recycled fraction: process GWP = GWPWasteToRecycling (lower than landfill)
    GWPActualProcess  += kgConverted * main.GWPWasteToRecycling[m];
    HTPActualProcess  += kgConverted * main.HTPWasteToRecycling[m];
    LUPActualProcess  += kgConverted * main.LUPWasteToRecycling[m];
    CEDActualProcess  += kgConverted * main.CEDWasteToRecycling[m];
    // Process waste fraction: landfill GWP (already sent to EoL above)
    GWPActualProcess  += kgProcWaste * main.GWPWasteToLandfill[m];
    HTPActualProcess  += kgProcWaste * main.HTPWasteToLandfill[m];
    LUPActualProcess  += kgProcWaste * main.LUPWasteToLandfill[m];
    CEDActualProcess  += kgProcWaste * main.CEDWasteToLandfill[m];
    GWPActualTotal     = GWPActualTransport + GWPActualProcess;

    // Reset buffer
    recyclingStoragePerMat[m] = 0;

    if (main.debugMode) traceln(String.format("Intermediate recyclingProcessing[%s]: raw=%.2f converted=%.2f waste=%.2f",
        MaterialType.values()[m], rawBuffer, converted, processWaste));
}

// Reset tier2 usage tracking (buffers were emptied)
tier2UsedCapacity = 0;]]></Body>
				</Function>
				<Function AccessType="public" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>9905000000001</Id>
					<Name><![CDATA[fulfillDemand]]></Name>
					<Description><![CDATA[Attempt to deliver requested quantity of a material to a Receiver from processed stock. Returns actual tonnes delivered (may be less than requested). Intermediate bears transport to Receiver; Receiver pays priceSecondary to Intermediate.]]></Description>
					<X>60</X><Y>1080</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Parameter>
						<Name><![CDATA[recv]]></Name>
						<Type><![CDATA[Receiver]]></Type>
					</Parameter>
					<Parameter>
						<Name><![CDATA[mat]]></Name>
						<Type><![CDATA[MaterialType]]></Type>
					</Parameter>
					<Parameter>
						<Name><![CDATA[requestedQty]]></Name>
						<Type><![CDATA[double]]></Type>
					</Parameter>
					<Body><![CDATA[// ═══ CE3.0: fulfillDemand — Intermediate → Receiver delivery ═══════════════
// Called synchronously by Receiver.calculateDemand().
// Delivers from currentStockPerMat (processed, saleable stock).
// Financial: Intermediate earns priceSecondary revenue; bears transport cost.
// LCA:       Intermediate bears transport GWP to receiver.
//            Receiver records its own cost in calculateDemand() (Step 3).

int matIdx = main.matIndex(mat);
double available = currentStockPerMat[matIdx];

if (available <= 0) {
    if (main.debugMode) traceln("Intermediate: no stock of " + mat + " for " + recv + " — full virgin fallback");
    return 0.0;
}

// Partial fulfillment if stock < demand
double delivered = Math.min(available, requestedQty);

// Deduct from saleable stock
currentStockPerMat[matIdx] -= delivered;

// ── Revenue to Intermediate (price paid by Receiver) ─────────────────────
// Note: Receiver debits the same amount in calculateDemand() Step 3.
// To avoid double-counting, revenue is recorded here only.
double revenue = delivered * main.priceSecondaryPerMat[matIdx]; // per-material from Materials col P
this.totalRevenues     += revenue;
this.financialBalance  += revenue;
main.totalSecondaryMaterial += delivered;

// ── Transport: Intermediate → Receiver (Intermediate bears cost + GWP) ───
double distKm = main.haversineKm(intermediateLat, intermediateLon,
                                  recv.receiverLat, recv.receiverLon);
double tCost  = main.transportCostCalc(delivered, distKm);
double GWPISTransportToIntermediate   = main.transportGWPCalc(delivered, distKm);
this.totalCosts        += tCost;
this.financialBalance  -= tCost;
main.networkTotalTransportCostISProcesses += tCost;
main.transportGWPISProcesses  += GWPISTransportToIntermediate;
main.totalTransportCost += tCost;
main.totalTransportGWP  += GWPISTransportToIntermediate;

if (main.debugMode) traceln("Intermediate fulfillDemand: " + String.format("%.2f", delivered) + " t " + mat + " → " + recv
    + " | revenue=" + String.format("%.2f", revenue) + " SGD | tCost=" + String.format("%.2f", tCost) + " SGD | dist=" + String.format("%.2f", distKm) + " km");
// ── LCA: delivery transport GWP (Intermediate → Receiver) ─────────────
GWPActualTransport += GWPISTransportToIntermediate;
GWPActualTotal      = GWPActualTransport + GWPActualProcess;
return delivered;]]></Body>
				</Function>
				<Function AccessType="public" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[boolean]]></ReturnType>
					<Id>9905000000002</Id>
					<Name><![CDATA[acceptResidue]]></Name>
					<Description><![CDATA[Accept processing residue from a Receiver back into Intermediate storage. Uses same 2-tier logic as acceptBooking() but takes coordinates instead of a Provider reference. Transport is already borne by the Receiver before this call.]]></Description>
					<X>60</X><Y>1110</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Parameter>
						<Name><![CDATA[mat]]></Name>
						<Type><![CDATA[MaterialType]]></Type>
					</Parameter>
					<Parameter>
						<Name><![CDATA[qty]]></Name>
						<Type><![CDATA[double]]></Type>
					</Parameter>
					<Parameter>
						<Name><![CDATA[fromLat]]></Name>
						<Type><![CDATA[double]]></Type>
					</Parameter>
					<Parameter>
						<Name><![CDATA[fromLon]]></Name>
						<Type><![CDATA[double]]></Type>
					</Parameter>
					<Body><![CDATA[// ═══ CE3.0: acceptResidue — Receiver processing residue → Intermediate ═══
// Identical 2-tier acceptance logic to acceptBooking().
// Transport to Intermediate has already been charged to the Receiver before
// this call — no further transport cost is recorded here.
// fromLat / fromLon are retained in the signature for potential future use
// (e.g. transport cost verification or GIS logging) but are intentionally
// unused here — the caller has already accounted for transport.
// The residue enters recyclingStoragePerMat and will be processed in next
// recyclingProcessing() cycle.

int matIdx = main.matIndex(mat);
totalBookingsReceived[matIdx]++;

double tier1Free = tier1CapPerMat[matIdx] - recyclingStoragePerMat[matIdx]; // Tier 1 = raw waste buffer only; currentStockPerMat is Tier 2 processed stock (separate pool)
if (tier1Free < 0) tier1Free = 0;

if (qty <= tier1Free) {
    recyclingStoragePerMat[matIdx] += qty;
    totalBookingsAccepted[matIdx]++;
    if (main.debugMode) traceln("Intermediate acceptResidue[" + mat + "]: " + String.format("%.2f", qty) + " t (Tier1)");
    return true;
}

double tier2Free = tier2SharedCapacity - tier2UsedCapacity;
double neededFromTier2 = qty - tier1Free;

if (neededFromTier2 <= tier2Free) {
    recyclingStoragePerMat[matIdx] += qty;
    tier2UsedCapacity += neededFromTier2;
    totalBookingsAccepted[matIdx]++;
    if (main.debugMode) traceln("Intermediate acceptResidue[" + mat + "]: " + String.format("%.2f", qty) + " t (Tier1+Tier2)");
    return true;
}

// No space — residue goes to EndOfLife at Receiver's expense (already transported; no extra cost here)
totalBookingsRejected[matIdx]++;
if (main.debugMode) traceln("Intermediate acceptResidue[" + mat + "]: REJECTED (storage full). " + String.format("%.2f", qty) + " t → landfill");
return false;]]></Body>
				</Function>
				<Function>
					<ReturnType><![CDATA[void]]></ReturnType>
					<Id>8800000303001</Id>
					<Name><![CDATA[receiveLandfillWaste]]></Name>
					<Description><![CDATA[Called by a GarbageTruck on arrival at Intermediate after a non-IS landfill run. Adds payload to WasteToBeBurned buffer. The weekly combustionDES will incinerate it.]]></Description>
					<X>60</X><Y>1380</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Parameter>
						<Name><![CDATA[qty]]></Name>
						<Type><![CDATA[double]]></Type>
					</Parameter>
					<Body><![CDATA[// ─── CE3.0: Receive landfill waste from non-IS Provider truck ───────────
// Called from GarbageTruck.home entry action when isLandfillRun = true.
// qty (tonnes) is added to the incineration buffer.
// The weeklyLandfillBurnEvent will trigger the combustion DES once
// WasteToBeBurned >= burningThreshold_t.
WasteToBeBurned      += qty;
totalWasteReceived   += qty;
traceln(String.format(
    "[LANDFILL-RECEIVE] t=%.2fd | +%.3ft → WasteToBeBurned=%.3ft (threshold=%.1ft isBurning=%b)",
    time(DAY), qty, WasteToBeBurned, burningThreshold_t, isBurning));
]]></Body>
				</Function>
			</Functions>
			<AgentLinks>
