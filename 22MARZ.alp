					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[Color]]></ReturnType>
					<Id>1772077166997</Id>
					<Name><![CDATA[getMaterialColor]]></Name>
					<X>10</X><Y>470</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[if (myMaterial == MaterialType.PLASTIC_SCRAP) return blue;
else if (myMaterial == MaterialType.PAPER_WASTE) return saddleBrown;
else if (myMaterial == MaterialType.FERROUS_METAL) return gray;
else if (myMaterial == MaterialType.TEXTILE_WASTE) return orange;
else if (myMaterial == MaterialType.NON_FERROUS_METAL) return darkGreen;
else return black;]]></Body>
				</Function>
