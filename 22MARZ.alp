// ─── Debug flag — set to true to enable verbose runtime traceln output ──────────
boolean debugMode = false;

// ═══════════════════════════════════════════════════════════════════════════════
// PER-MATERIAL LCA PARAMETER ARRAYS
// Index: 0=PLASTIC_SCRAP, 1=PAPER_WASTE, 2=FERROUS_METAL, 3=TEXTILE_WASTE, 4=NON_FERROUS_METAL
// ═══════════════════════════════════════════════════════════════════════════════
//
// Global Warming Potential (kg CO2-eq/kg) — ReCiPe 2016 v1.03 midpoint (H)
// Sources:
//   PLASTIC_SCRAP GWP: [V] Franklin Associates (2011) Table 2-5 — HDPE NA cradle-to-resin.
//   All materials: emissionFactors sheet (ecoinvent 3.9 / ReCiPe 2016 v1.03).
//   PLASTIC_SCRAP     → HDPE (Polyethylene, high density) — Franklin Associates (2011)
//   PAPER_WASTE        → Graphic paper — ecoinvent 3.9
//   FERROUS_METAL      → Reinforcement steel — ecoinvent 3.9
//   TEXTILE_WASTE      → Cotton fibre — ecoinvent 3.9 / Miljögiraff (2016)
//   NON_FERROUS_METAL  → Aluminium, cast alloy — ecoinvent 3.9
double[] GWPVirginPerKg   = new double[5];  // kg CO2-eq / kg virgin — emissionFactors sheet (ecoinvent 3.9 / ReCiPe 2016 v1.03 midpoint H)
double[] GWPWasteToRecycling = new double[5];  // kg CO2-eq / kg recycled (IS pathway)
double[] GWPWasteToLandfill = new double[5];  // kg CO2-eq / kg landfilled

// Human Toxicity Potential non-carcinogenic (kg 1,4-DCB-eq/kg) — ReCiPe 2016 v1.03 midpoint (H)
// Sources: emissionFactors sheet — ecoinvent 3.9 / ReCiPe 2016 v1.03 midpoint (H)
double[] HTPVirginPerKg   = new double[5];  // kg 1,4-DCB-eq / kg virgin — emissionFactors sheet
double[] HTPWasteToRecycling = new double[5];
double[] HTPWasteToLandfill = new double[5];  // kg 1,4-DCB-eq / kg landfilled — emissionFactors sheet

// Agricultural Land Occupation (m2*a crop-eq / kg) — ReCiPe 2016 v1.03
// Sources: emissionFactors sheet — ecoinvent 3.9 / ReCiPe 2016 v1.03 midpoint (H)
double[] LUPVirginPerKg   = new double[5];  // m2*a crop-eq / kg virgin — emissionFactors sheet
double[] LUPWasteToRecycling = new double[5];
double[] LUPWasteToLandfill = new double[5];

// Cumulative Energy Demand — CED (MJ / kg) — ecoinvent 3.9, CED v1.11
// Sources: Materials sheet / ecoinvent 3.9, CED v1.11
double[] CEDVirginPerKg   = new double[5];  // MJ / kg virgin production — Materials sheet / ecoinvent 3.9
double[] CEDWasteToRecycling = new double[5];  // MJ / kg through IS/recycling
double[] CEDWasteToLandfill = new double[5];  // MJ / kg landfill operations

// ═══════════════════════════════════════════════════════════════════════════════
// PER-MATERIAL KPI TRACKING ARRAYS (index = MaterialType.values()[i])
// ═══════════════════════════════════════════════════════════════════════════════
double[] co2SavedPerMat      = {0, 0, 0, 0, 0};   // kg CO2-eq saved
double[] HTPSavedPerMat      = {0, 0, 0, 0, 0};   // kg 1,4-DCB-eq avoided
double[] LUPSavedPerMat      = {0, 0, 0, 0, 0};   // m2*a avoided
double[] CEDSavedPerMat      = {0, 0, 0, 0, 0};   // MJ avoided
double[] exchangedPerMat     = {0, 0, 0, 0, 0};   // tonnes exchanged
double[] landfillCostPerMat  = {0, 0, 0, 0, 0};   // USD disposal costs

// ═══════════════════════════════════════════════════════════════════════════════
// TIME-SERIES LOGGING (for CSV export after experiment)
// ═══════════════════════════════════════════════════════════════════════════════
java.util.ArrayList<Double> timeLog        = new java.util.ArrayList<>();
java.util.ArrayList<Double> npvLog         = new java.util.ArrayList<>();
java.util.ArrayList<Double> co2Log         = new java.util.ArrayList<>();
java.util.ArrayList<Double> HTPLog         = new java.util.ArrayList<>();
java.util.ArrayList<Double> LUPLog         = new java.util.ArrayList<>();
java.util.ArrayList<Double> CEDLog         = new java.util.ArrayList<>();
java.util.ArrayList<Double> exchangedLog   = new java.util.ArrayList<>();
java.util.ArrayList<Double> landfillLog    = new java.util.ArrayList<>();

// Helper: get LCA index for a material type
public int matIndex(MaterialType m) {
    for (int i = 0; i < MaterialType.values().length; i++)
        if (MaterialType.values()[i] == m) return i;
    return 0;
}

// GIS distance in km between two lat/lon points (Finneiss approach: map.getDistance)
// map.getDistance(lat1, lon1, lat2, lon2) returns metres — divide by 1000 for km.
public double haversineKm(double lat1, double lon1, double lat2, double lon2) {
    return map.getDistance(lat1, lon1, lat2, lon2) / 1000.0;
}

// Transport LCA: returns GWP in kg CO2-eq for transporting mass_t tonnes over dist_km
public double transportGWPCalc(double mass_t, double dist_km) {
    return mass_t * 1000.0 * dist_km * transportGWP; // mass_t*1000 = kg
}

// Transport cost in SGD
public double transportCostCalc(double mass_t, double dist_km) {
    return mass_t * dist_km * transportCost;
}

// Get number of providers from Excel
public int getProviderCount() {
    return 66; // 66 providers from Companies_Listing sheet rows 2-67 (VNTT + NEW CHOICE FOOD removed; 13 duplicates removed — 11 cross-entry + 2 Finneis name variants)
}

// Helper: export all ArrayLists to CSV
public void exportToCSV(String filePath) {
    try {
        java.io.PrintWriter pw = new java.io.PrintWriter(new java.io.FileWriter(filePath));
        pw.println("year,time_days,NPV_SGD,GWP_saved_kgCO2eq,HTP_saved_kgDCBeq,LUP_saved_m2a,CED_saved_MJ,exchanged_t,landfill_cost_SGD");
        for (int i = 0; i < timeLog.size(); i++) {
            pw.printf("%.0f,%.1f,%.2f,%.2f,%.4f,%.4f,%.2f,%.2f,%.2f%n",
                (double)(i+1), timeLog.get(i), npvLog.get(i),
                co2Log.get(i), HTPLog.get(i), LUPLog.get(i),
                CEDLog.get(i), exchangedLog.get(i), landfillLog.get(i));
        }
        pw.close();
        traceln("CSV exported to: " + filePath);
    } catch (Exception e) {
        traceln("CSV export error: " + e.getMessage());
    }
}


// ═══════════════════════════════════════════════════════════════════════════════
// PER-MATERIAL PRICING AND OPERATIONAL PARAMETERS (CE 3.0)
// Index: 0=PLASTIC_SCRAP, 1=PAPER_WASTE, 2=FERROUS_METAL, 3=TEXTILE_WASTE, 4=NON_FERROUS_METAL
// ═══════════════════════════════════════════════════════════════════════════════

// Market prices (SGD per tonne)
double[] priceVirginPerMat    = new double[5];    // Primary (virgin) material purchase price; Materials col O
double[] priceSecondaryPerMat = new double[5];    // Secondary (recycled) material sale price;  Materials col P
double[] costLandfillPerMat   = new double[5];    // Landfill disposal cost per material;       Materials col Q
double[] conversionEffPerMat  = new double[5];  // Recycling efficiency
double[] processingEffPerMat  = new double[5];  // Receiver production efficiency per material

// Provider payment per material (SGD/tonne)
// Index: 0=PLASTIC_SCRAP, 1=PAPER_WASTE, 2=FERROUS_METAL, 3=TEXTILE_WASTE, 4=NON_FERROUS_METAL
// Positive = Intermediate PAYS Provider (high-value materials: metals)
// Negative = Provider PAYS Intermediate (low-value: plastics, textiles)
// Default calibration: provider is financially indifferent between IS and landfill
//   → pricePaidToProvider[i] = costLandfillPerMat[i] (IS saves only environmental burden)
// TODO: replace with per-material Excel values once calibrated
double[] pricePaidToProvider  = new double[5];  // SGD/t (neg=provider pays, pos=provider receives)

// Transport parameters
double transportGWP  = 0.000206378;   // kg CO2-eq per kg*km (truck diesel)
double transportCost = 0.10;          // SGD per tonne*km



// ═══════════════════════════════════════════════════════════════════════════════
// BOOKING LOG EXPORT  (Apache POI XSSF — bundled with AnyLogic 8.9.x)
// Called automatically from FinishActions at simulation end.
// Output: simulation_results_YYYYMMDD_HHmmss.xlsx  in the model project folder.
// ═══════════════════════════════════════════════════════════════════════════════
public void exportBookingLog() {
    try {
        // ── file path ────────────────────────────────────────────────────────
        String ts = new java.text.SimpleDateFormat("yyyyMMdd_HHmmss")
                        .format(new java.util.Date());
        String filePath = System.getProperty("user.dir")
                        + java.io.File.separator
                        + "simulation_results_" + ts + ".xlsx";

        org.apache.poi.xssf.usermodel.XSSFWorkbook wb =
            new org.apache.poi.xssf.usermodel.XSSFWorkbook();

        // ── bold header style ─────────────────────────────────────────────────
        org.apache.poi.xssf.usermodel.XSSFCellStyle boldStyle = wb.createCellStyle();
        org.apache.poi.xssf.usermodel.XSSFFont boldFont = wb.createFont();
        boldFont.setBold(true);
        boldStyle.setFont(boldFont);

        // ── Sheet 1: Booking Log ──────────────────────────────────────────────
        org.apache.poi.xssf.usermodel.XSSFSheet logSh = wb.createSheet("Booking Log");
        String[] logHdr = {
            "SimDay", "Provider_Index", "Material", "Amount_t",
            "Result", "StorageTier_or_Reason", "Dist_to_Intermediate_km",
            "TransportCost_SGD"
        };
        org.apache.poi.xssf.usermodel.XSSFRow h0 = logSh.createRow(0);
        for (int c2 = 0; c2 < logHdr.length; c2++) {
            org.apache.poi.xssf.usermodel.XSSFCell cell = h0.createCell(c2);
            cell.setCellValue(logHdr[c2]);
            cell.setCellStyle(boldStyle);
        }
        @SuppressWarnings("unchecked")
        java.util.ArrayList<Object[]> log =
            (java.util.ArrayList<Object[]>) intermediate.bookingLog;
        for (int r = 0; r < log.size(); r++) {
            Object[] rec = log.get(r);
            org.apache.poi.xssf.usermodel.XSSFRow row = logSh.createRow(r + 1);
            row.createCell(0).setCellValue(((Number) rec[0]).doubleValue()); // simDay
            row.createCell(1).setCellValue(((Number) rec[1]).intValue());    // provIdx
            row.createCell(2).setCellValue((String)  rec[2]);               // material
            row.createCell(3).setCellValue(((Number) rec[3]).doubleValue()); // amount
            row.createCell(4).setCellValue((String)  rec[4]);               // result
            row.createCell(5).setCellValue((String)  rec[5]);               // tier
            row.createCell(6).setCellValue(((Number) rec[6]).doubleValue()); // dist
            row.createCell(7).setCellValue(((Number) rec[7]).doubleValue()); // cost
        }
        // auto-size columns
        for (int c2 = 0; c2 < logHdr.length; c2++) logSh.autoSizeColumn(c2);

        // ── Sheet 2: Per-Material Summary ────────────────────────────────────
        org.apache.poi.xssf.usermodel.XSSFSheet sumSh = wb.createSheet("Summary");
        String[] sumHdr = {
            "Material", "Total_Received", "Total_Accepted",
            "Total_Rejected", "Acceptance_Rate_pct"
        };
        org.apache.poi.xssf.usermodel.XSSFRow h1 = sumSh.createRow(0);
        for (int c2 = 0; c2 < sumHdr.length; c2++) {
            org.apache.poi.xssf.usermodel.XSSFCell cell = h1.createCell(c2);
            cell.setCellValue(sumHdr[c2]);
            cell.setCellStyle(boldStyle);
        }
        String[] matNames = {
            "PLASTIC_SCRAP", "PAPER_WASTE", "FERROUS_METAL",
            "TEXTILE_WASTE", "NON_FERROUS_METAL"
        };
        for (int m = 0; m < 5; m++) {
            org.apache.poi.xssf.usermodel.XSSFRow row = sumSh.createRow(m + 1);
            int recv = intermediate.totalBookingsReceived[m];
            int acc  = intermediate.totalBookingsAccepted[m];
            int rej  = intermediate.totalBookingsRejected[m];
            row.createCell(0).setCellValue(matNames[m]);
            row.createCell(1).setCellValue(recv);
            row.createCell(2).setCellValue(acc);
            row.createCell(3).setCellValue(rej);
            row.createCell(4).setCellValue(recv > 0 ? (double) acc / recv * 100.0 : 0.0);
        }
        for (int c2 = 0; c2 < sumHdr.length; c2++) sumSh.autoSizeColumn(c2);

        // ── Sheet 3: KPI Time Series ──────────────────────────────────────────
        org.apache.poi.xssf.usermodel.XSSFSheet kpiSh = wb.createSheet("KPI TimeSeries");
        String[] kpiHdr = {
            "Year", "Time_days", "NPV_SGD", "CO2_saved_kg",
            "HTP_saved_kgDCB", "LUP_saved_m2a", "CED_saved_MJ",
            "Exchanged_t", "LandfillCost_SGD"
        };
        org.apache.poi.xssf.usermodel.XSSFRow h2 = kpiSh.createRow(0);
        for (int c2 = 0; c2 < kpiHdr.length; c2++) {
            org.apache.poi.xssf.usermodel.XSSFCell cell = h2.createCell(c2);
            cell.setCellValue(kpiHdr[c2]);
            cell.setCellStyle(boldStyle);
        }
        for (int i = 0; i < timeLog.size(); i++) {
            org.apache.poi.xssf.usermodel.XSSFRow row = kpiSh.createRow(i + 1);
            row.createCell(0).setCellValue(i);
            row.createCell(1).setCellValue(timeLog.get(i));
            row.createCell(2).setCellValue(npvLog.get(i));
            row.createCell(3).setCellValue(co2Log.get(i));
            row.createCell(4).setCellValue(HTPLog.get(i));
            row.createCell(5).setCellValue(LUPLog.get(i));
            row.createCell(6).setCellValue(CEDLog.get(i));
            row.createCell(7).setCellValue(exchangedLog.get(i));
            row.createCell(8).setCellValue(landfillLog.get(i));
        }
        for (int c2 = 0; c2 < kpiHdr.length; c2++) kpiSh.autoSizeColumn(c2);

        // ── save ──────────────────────────────────────────────────────────────
        java.io.FileOutputStream fos = new java.io.FileOutputStream(filePath);
        wb.write(fos);
        fos.close();
        wb.close();
        traceln("=== Simulation results exported: " + filePath
                + " (" + log.size() + " booking records) ===");

    } catch (Exception ex) {
        traceln("exportBookingLog ERROR: " + ex.getMessage());
        ex.printStackTrace();
    }
}

// ─── Navigation helpers (called by Provider/Receiver/GarbageTruck buttons) ─────
// Uses _origin_VA.navigateTo() — the field auto-generated by MakeDefaultViewArea=true.
// AnyLogic names this field _origin_VA on every agent class that has the flag set.
public void goToPrevProvider(Provider current) {
    int idx = 0;
    for (int i = 0; i < providers.size(); i++) {
        if (providers.get(i) == current) { idx = i; break; }
    }
    int prev = (idx - 1 + providers.size()) % providers.size();
    providers.get(prev)._origin_VA.navigateTo();
}

public void goToNextProvider(Provider current) {
    int idx = 0;
    for (int i = 0; i < providers.size(); i++) {
        if (providers.get(i) == current) { idx = i; break; }
    }
    int next = (idx + 1) % providers.size();
    providers.get(next)._origin_VA.navigateTo();
}

public void goToIntermediate() {
    intermediate._origin_VA.navigateTo();
}

public void goToNextTruck(GarbageTruck current) {
    int idx = 0;
    for (int i = 0; i < garbageTrucks.size(); i++) {
        if (garbageTrucks.get(i) == current) { idx = i; break; }
    }
    int next = (idx + 1) % garbageTrucks.size();
    garbageTrucks.get(next)._origin_VA.navigateTo();
}

public void goToMyTruck(Provider prov) {
    int pIdx = prov.getIndex();
    if (pIdx >= 0 && pIdx < garbageTrucks.size()) {
        garbageTrucks.get(pIdx)._origin_VA.navigateTo();
    }
}

public void goToMyProvider(GarbageTruck gt) {
    if (gt.myProviderIndex >= 0 && gt.myProviderIndex < providers.size()) {
        providers.get(gt.myProviderIndex)._origin_VA.navigateTo();
    } else if (gt.sourceProvider != null) {
        ((Provider) gt.sourceProvider)._origin_VA.navigateTo();
    }
}




// ═══════════════════════════════════════════════════════════════════════════════
// EXCEL CONNECTION VALIDATION — CE 3.0 / 22MARZ
// Checks all Excel-linked values after startup reads.
// Populates validationErrors list; call exportValidationReport() to write XLSX.
// ═══════════════════════════════════════════════════════════════════════════════
java.util.ArrayList<String[]> validationErrors = new java.util.ArrayList<>();

public void validateExcelConnections() {
    validationErrors.clear();
    String[] MAT = {"PLASTIC_SCRAP","PAPER_WASTE","FERROUS_METAL","TEXTILE_WASTE","NON_FERROUS_METAL"};
    int[]    MAT_ROW = {3, 4, 5, 6, 7};

    // ── Materials sheet ────────────────────────────────────────────────────────
    for (int m = 0; m < 5; m++) {
        int r = MAT_ROW[m];
        chkRange("Materials", "conversionEffPerMat["+m+"] ("+MAT[m]+")",   "B", r, conversionEffPerMat[m],   0.01, 1.0,   false);
        chkRange("Materials", "GWPVirginPerKg["+m+"] ("+MAT[m]+")",        "C", r, GWPVirginPerKg[m],        0.0,  1e9,   false);
        chkRange("Materials", "GWPWasteToRecycling["+m+"] ("+MAT[m]+")",   "D", r, GWPWasteToRecycling[m],   0.0,  1e9,   true);
        chkRange("Materials", "GWPWasteToLandfill["+m+"] ("+MAT[m]+")",    "E", r, GWPWasteToLandfill[m],    0.0,  1e9,   false);
        chkRange("Materials", "HTPVirginPerKg["+m+"] ("+MAT[m]+")",        "F", r, HTPVirginPerKg[m],        0.0,  1e9,   true);
        chkRange("Materials", "HTPWasteToRecycling["+m+"] ("+MAT[m]+")",   "G", r, HTPWasteToRecycling[m],   0.0,  1e9,   true);
        chkRange("Materials", "HTPWasteToLandfill["+m+"] ("+MAT[m]+")",    "H", r, HTPWasteToLandfill[m],    0.0,  1e9,   true);
        chkRange("Materials", "LUPVirginPerKg["+m+"] ("+MAT[m]+")",        "I", r, LUPVirginPerKg[m],        0.0,  1e9,   true);
        chkRange("Materials", "LUPWasteToRecycling["+m+"] ("+MAT[m]+")",   "J", r, LUPWasteToRecycling[m],   0.0,  1e9,   true);
        chkRange("Materials", "LUPWasteToLandfill["+m+"] ("+MAT[m]+")",    "K", r, LUPWasteToLandfill[m],    0.0,  1e9,   true);
        chkRange("Materials", "CEDVirginPerKg["+m+"] ("+MAT[m]+")",        "L", r, CEDVirginPerKg[m],        0.0,  1e9,   false);
        chkRange("Materials", "CEDWasteToRecycling["+m+"] ("+MAT[m]+")",   "M", r, CEDWasteToRecycling[m],   0.0,  1e9,   true);
        chkRange("Materials", "CEDWasteToLandfill["+m+"] ("+MAT[m]+")",    "N", r, CEDWasteToLandfill[m],    0.0,  1e9,   true);
        chkRange("Materials", "priceVirginPerMat["+m+"] ("+MAT[m]+")",     "O", r, priceVirginPerMat[m],     0.01, 1e6,   false);
        chkRange("Materials", "priceSecondaryPerMat["+m+"] ("+MAT[m]+")",  "P", r, priceSecondaryPerMat[m],  0.01, 1e6,   false);
        chkRange("Materials", "costLandfillPerMat["+m+"] ("+MAT[m]+")",    "Q", r, costLandfillPerMat[m],    0.0,  1e6,   false);
        chkRange("Materials", "pricePaidToProvider["+m+"] ("+MAT[m]+")",   "V", r, pricePaidToProvider[m],  -1e6, 1e6,   false);
    }

    // ── recycling_and processingfactors sheet ──────────────────────────────────
    int[] PROC_ROWS = {5, 7, 9, 11, 13};
    for (int m = 0; m < 5; m++) {
        chkRange("recycling_and processingfactors", "processingEffPerMat["+m+"] ("+MAT[m]+")",
                 "C", PROC_ROWS[m], processingEffPerMat[m], 0.01, 1.0, false);
    }

    // ── Intermediate sheet ─────────────────────────────────────────────────────
    chkRange("Intermediate", "totalStorageCapacity",       "B", 3,  intermediate.totalStorageCapacity, 1.0,   1e7,  false);
    chkRange("Intermediate", "tier1Pct (Tier1 fraction)",  "B", 4,  Input_data.getCellNumericValue("Intermediate",4,2), 0.01, 0.99, false);
    chkRange("Intermediate", "capexPerStorageUnit",        "B", 7,  capexPerStorageUnit,               0.01,  1e6,  false);
    chkRange("Intermediate", "opexPerStorageUnitPerMonth", "B", 8,  opexPerStorageUnitPerMonth,        0.0,   1e5,  false);
    chkRange("Intermediate", "salvageValuePercent",        "B", 9,  salvageValuePercent,               0.0,   1.0,  false);
    chkRange("Intermediate", "discountRate",               "B", 10, discountRate,                      0.001, 0.5,  false);
    // ── Intermediate: incineration parameters ──────────────────────────────
    intermediate.burningThreshold_t        = Input_data.getCellNumericValue("Intermediate", 11, 2);
    intermediate.emissionFactor_CO2_kgPerKg = Input_data.getCellNumericValue("Intermediate", 12, 2);
    intermediate.emissionFactor_CO_kgPerKg  = Input_data.getCellNumericValue("Intermediate", 13, 2);
    intermediate.emissionFactor_NOx_kgPerKg = Input_data.getCellNumericValue("Intermediate", 14, 2);
    chkRange("Intermediate", "burningThreshold_t",          "B", 11, intermediate.burningThreshold_t,          1.0,   1e5,  false);
    chkRange("Intermediate", "emissionFactor_CO2_kgPerKg",  "B", 12, intermediate.emissionFactor_CO2_kgPerKg,  0.0,   5.0,  false);
    chkRange("Intermediate", "emissionFactor_CO_kgPerKg",   "B", 13, intermediate.emissionFactor_CO_kgPerKg,   0.0,   1.0,  false);
    chkRange("Intermediate", "emissionFactor_NOx_kgPerKg",  "B", 14, intermediate.emissionFactor_NOx_kgPerKg,  0.0,   1.0,  false);

    // ── TruckFleet sheet (Phase 2: single global parameter row) ──────────────
    // CE3.0 Phase 2: old per-AgentType rows removed. Now one data row (row 3) with 11 cols.
    chkRange("TruckFleet", "truckVelocity_kmh",    "A", 3, Input_data.getCellNumericValue("TruckFleet",3,1),  1.0,   200.0, false);
    chkRange("TruckFleet", "loadingTime_h",         "B", 3, Input_data.getCellNumericValue("TruckFleet",3,2),  0.0,   24.0,  false);
    chkRange("TruckFleet", "unloadingTime_h",       "C", 3, Input_data.getCellNumericValue("TruckFleet",3,3),  0.0,   24.0,  false);
    chkRange("TruckFleet", "jollyTruckCount",       "I", 3, (double) intermediate.truckCount,                  1.0,   100.0, false);
    chkRange("TruckFleet", "jollyPremiumFactor",    "J", 3, Input_data.getCellNumericValue("TruckFleet",3,10), 1.0,   5.0,   false);
    chkRange("TruckFleet", "truckCapex_SGD",        "K", 3, Input_data.getCellNumericValue("TruckFleet",3,11), 0.0,   1e7,   false);

    // ── Companies_Listing — Intermediate & EndOfLife ─────────────────────────
    chkCoord("Companies_Listing", "intermediateLat", "E", 73, intermediateLat);
    chkCoord("Companies_Listing", "intermediateLon", "F", 73, intermediateLon);
    // endOfLifeLat/Lon = intermediateLat/Lon (CE3.0 Phase 1) - no separate check needed

    // ── Companies_Listing — Providers (rows 2-67) ────────────────────────────
    for (int i = 0; i < providers.size(); i++) {
        Provider p = providers.get(i);
        int row = 2 + i;
        chkCoord("Companies_Listing", "Provider["+i+"] ("+p.companyName+") providerLat", "E", row, p.providerLat);
        chkCoord("Companies_Listing", "Provider["+i+"] ("+p.companyName+") providerLon", "F", row, p.providerLon);
        chkRange("Companies_Listing", "Provider["+i+"] ("+p.companyName+") avgSupplyFromExcel", "G", row, p.avgSupplyFromExcel, 0.01, 5000.0, false);
        chkRange("Companies_Listing", "Provider["+i+"] ("+p.companyName+") supplyVariability",  "H", row, p.supplyVariability,  0.01, 1.0,    false);
    }

    // ── Companies_Listing — Receivers (rows 68-72) ───────────────────────────
    String[] recNames = {"Receiver_Plastic","Receiver_Paper","Receiver_Ferrous","Receiver_Textile","Receiver_NonFerrous"};
    for (int i = 0; i < receivers.size(); i++) {
        Receiver r = receivers.get(i);
        int row = 68 + i;
        chkCoord("Companies_Listing", recNames[i]+" receiverLat",          "E", row, r.receiverLat);
        chkCoord("Companies_Listing", recNames[i]+" receiverLon",          "F", row, r.receiverLon);
        chkRange("Companies_Listing", recNames[i]+" avgDemandFromExcel",   "G", row, r.avgDemandFromExcel,   0.01, 5000.0, false);
        chkRange("Companies_Listing", recNames[i]+" demandVariability",    "H", row, r.demandVariability,    0.01, 1.0,    false);
        if (r.processingEfficiency < 0) {
            validationErrors.add(new String[]{
                recNames[i], "processingEfficiency", "recycling_and processingfactors",
                "C", String.valueOf(new int[]{5,7,9,11,13}[i]),
                String.valueOf(r.processingEfficiency),
                "SENTINEL -1.0: value not loaded from Excel. Check sheet 'recycling_and processingfactors' col C.",
                "(0, 1]"
            });
        }
    }

    if (validationErrors.isEmpty())
        traceln("[CE3 Validation] All " + getTotalChecks() + " Excel connections OK.");
    else
        traceln("[CE3 Validation] WARNING: " + validationErrors.size() + " connection error(s). Run exportValidationReport().");
}

private int totalChecks = 0;
private int getTotalChecks() { return totalChecks; }

private void chkRange(String sheet, String variable, String col, int row,
                      double value, double min, double max, boolean zeroOk) {
    totalChecks++;
    boolean blank = (value == 0.0 && !zeroOk);
    boolean outOfRange = (value < min || value > max);
    if (blank || outOfRange) {
        String issue = blank
            ? "Blank or zero cell — likely missing value in Excel"
            : "Value " + String.format("%.6g", value) + " is outside expected range [" + min + ", " + max + "]";
        validationErrors.add(new String[]{
            variable, sheet, col, String.valueOf(row),
            String.format("%.6g", value), issue,
            "[" + min + ", " + max + "]"
        });
    }
}

private void chkCoord(String sheet, String variable, String col, int row, double value) {
    totalChecks++;
    if (value == 0.0 || (value > -1.0 && value < 1.0)) {
        validationErrors.add(new String[]{
            variable, sheet, col, String.valueOf(row),
            String.format("%.6f", value),
            "Coordinate is zero or near-zero — likely blank cell in Excel",
            "Non-zero GPS coordinate"
        });
    }
}


public void exportValidationReport() {
    String fileName = "22MARZ_ValidationReport.xlsx";
    String outPath  = System.getProperty("user.dir") + java.io.File.separator + fileName;

    try {
        org.apache.poi.xssf.usermodel.XSSFWorkbook wb = new org.apache.poi.xssf.usermodel.XSSFWorkbook();

        // ── Styles ────────────────────────────────────────────────────────────
        org.apache.poi.xssf.usermodel.XSSFCellStyle hdrStyle = wb.createCellStyle();
        org.apache.poi.xssf.usermodel.XSSFFontFormatting unused = null; // avoid import issues
        org.apache.poi.xssf.usermodel.XSSFFont hdrFont = wb.createFont();
        hdrFont.setBold(true);
        hdrFont.setFontHeightInPoints((short)11);
        hdrStyle.setFont(hdrFont);
        hdrStyle.setFillForegroundColor(new org.apache.poi.xssf.usermodel.XSSFColor(new byte[]{(byte)31,(byte)73,(byte)125}, null));
        hdrStyle.setFillPattern(org.apache.poi.ss.usermodel.FillPatternType.SOLID_FOREGROUND);
        hdrFont.setColor(new org.apache.poi.xssf.usermodel.XSSFColor(new byte[]{(byte)255,(byte)255,(byte)255}, null));

        org.apache.poi.xssf.usermodel.XSSFCellStyle errStyle = wb.createCellStyle();
        errStyle.setFillForegroundColor(new org.apache.poi.xssf.usermodel.XSSFColor(new byte[]{(byte)255,(byte)199,(byte)206}, null));
        errStyle.setFillPattern(org.apache.poi.ss.usermodel.FillPatternType.SOLID_FOREGROUND);

        org.apache.poi.xssf.usermodel.XSSFCellStyle okStyle = wb.createCellStyle();
        okStyle.setFillForegroundColor(new org.apache.poi.xssf.usermodel.XSSFColor(new byte[]{(byte)198,(byte)239,(byte)206}, null));
        okStyle.setFillPattern(org.apache.poi.ss.usermodel.FillPatternType.SOLID_FOREGROUND);

        org.apache.poi.xssf.usermodel.XSSFCellStyle wrapStyle = wb.createCellStyle();
        wrapStyle.setWrapText(true);
        wrapStyle.setFillForegroundColor(new org.apache.poi.xssf.usermodel.XSSFColor(new byte[]{(byte)255,(byte)199,(byte)206}, null));
        wrapStyle.setFillPattern(org.apache.poi.ss.usermodel.FillPatternType.SOLID_FOREGROUND);

        // ── Sheet 1: Summary ──────────────────────────────────────────────────
        org.apache.poi.xssf.usermodel.XSSFSheet summary = wb.createSheet("Summary");
        summary.setColumnWidth(0, 10000);
        summary.setColumnWidth(1, 8000);

        org.apache.poi.xssf.usermodel.XSSFRow titleRow = summary.createRow(0);
        org.apache.poi.xssf.usermodel.XSSFCell titleCell = titleRow.createCell(0);
        titleCell.setCellValue("CE 3.0 — 22MARZ Excel Connection Validation Report");
        org.apache.poi.xssf.usermodel.XSSFFont titleFont = wb.createFont();
        titleFont.setBold(true); titleFont.setFontHeightInPoints((short)14);
        org.apache.poi.xssf.usermodel.XSSFCellStyle titleStyle = wb.createCellStyle();
        titleStyle.setFont(titleFont);
        titleCell.setCellStyle(titleStyle);

        summary.createRow(1).createCell(0).setCellValue("Generated: " + new java.util.Date().toString());
        summary.createRow(2).createCell(0).setCellValue("Simulation time at export: " + String.format("%.1f days", time()));
        summary.createRow(3).createCell(0).setCellValue("Total checks performed: " + getTotalChecks());

        org.apache.poi.xssf.usermodel.XSSFRow statusRow = summary.createRow(4);
        org.apache.poi.xssf.usermodel.XSSFCell statusCell = statusRow.createCell(0);
        if (validationErrors.isEmpty()) {
            statusCell.setCellValue("STATUS: ALL CHECKS PASSED — No Excel connection errors found.");
            statusCell.setCellStyle(okStyle);
        } else {
            statusCell.setCellValue("STATUS: " + validationErrors.size() + " ERROR(S) FOUND — See 'Errors' sheet.");
            statusCell.setCellStyle(errStyle);
        }

        // ── Sheet 2: Errors ───────────────────────────────────────────────────
        org.apache.poi.xssf.usermodel.XSSFSheet errSheet = wb.createSheet("Errors");
        errSheet.setColumnWidth(0, 9000);
        errSheet.setColumnWidth(1, 7000);
        errSheet.setColumnWidth(2, 4000);
        errSheet.setColumnWidth(3, 3000);
        errSheet.setColumnWidth(4, 3000);
        errSheet.setColumnWidth(5, 14000);
        errSheet.setColumnWidth(6, 6000);

        org.apache.poi.xssf.usermodel.XSSFRow errHdr = errSheet.createRow(0);
        String[] errCols = {"Variable / Agent","Excel Sheet","Column","Row","Value Found","Issue Description","Expected Range"};
        for (int c = 0; c < errCols.length; c++) {
            org.apache.poi.xssf.usermodel.XSSFCell cell = errHdr.createCell(c);
            cell.setCellValue(errCols[c]);
            cell.setCellStyle(hdrStyle);
        }

        if (validationErrors.isEmpty()) {
            org.apache.poi.xssf.usermodel.XSSFRow okRow = errSheet.createRow(1);
            org.apache.poi.xssf.usermodel.XSSFCell okCell = okRow.createCell(0);
            okCell.setCellValue("No errors found. All Excel connections are valid.");
            okCell.setCellStyle(okStyle);
        } else {
            for (int i = 0; i < validationErrors.size(); i++) {
                String[] e = validationErrors.get(i);
                org.apache.poi.xssf.usermodel.XSSFRow eRow = errSheet.createRow(i + 1);
                eRow.setHeightInPoints(40);
                for (int c = 0; c < e.length; c++) {
                    org.apache.poi.xssf.usermodel.XSSFCell cell = eRow.createCell(c);
                    cell.setCellValue(e[c]);
                    cell.setCellStyle(c == 5 ? wrapStyle : errStyle);
                }
            }
        }

        // ── Sheet 3: Full Connection Map ──────────────────────────────────────
        org.apache.poi.xssf.usermodel.XSSFSheet mapSheet = wb.createSheet("Connection Map");
        mapSheet.setColumnWidth(0, 10000);
        mapSheet.setColumnWidth(1, 8000);
        mapSheet.setColumnWidth(2, 3500);
        mapSheet.setColumnWidth(3, 3500);
        mapSheet.setColumnWidth(4, 5000);
        mapSheet.setColumnWidth(5, 4000);
        mapSheet.setColumnWidth(6, 5000);

        org.apache.poi.xssf.usermodel.XSSFRow mapHdr = mapSheet.createRow(0);
        String[] mapCols = {"AnyLogic Variable","Excel Sheet","Column","Row(s)","Agent","Valid Range","Current Value"};
        for (int c = 0; c < mapCols.length; c++) {
            org.apache.poi.xssf.usermodel.XSSFCell cell = mapHdr.createCell(c);
            cell.setCellValue(mapCols[c]);
            cell.setCellStyle(hdrStyle);
        }

        String[] MAT = {"PLASTIC_SCRAP","PAPER_WASTE","FERROUS_METAL","TEXTILE_WASTE","NON_FERROUS_METAL"};
        int mapRow = 1;
        String[][] connectionMap = {
            // {variable, sheet, col, rows, agent, range, note}
            {"conversionEffPerMat[0..4]","Materials","B","3-7","Intermediate","(0,1]","per material"},
            {"GWPVirginPerKg[0..4]","Materials","C","3-7","Main",">=0","per material"},
            {"GWPWasteToRecycling[0..4]","Materials","D","3-7","Main",">=0","per material"},
            {"GWPWasteToLandfill[0..4]","Materials","E","3-7","Main",">=0","per material"},
            {"HTPVirginPerKg[0..4]","Materials","F","3-7","Main",">=0","per material"},
            {"HTPWasteToRecycling[0..4]","Materials","G","3-7","Main",">=0","per material"},
            {"HTPWasteToLandfill[0..4]","Materials","H","3-7","Main",">=0","per material"},
            {"LUPVirginPerKg[0..4]","Materials","I","3-7","Main",">=0","per material"},
            {"LUPWasteToRecycling[0..4]","Materials","J","3-7","Main",">=0","per material"},
            {"LUPWasteToLandfill[0..4]","Materials","K","3-7","Main",">=0","per material"},
            {"CEDVirginPerKg[0..4]","Materials","L","3-7","Main",">=0","per material"},
            {"CEDWasteToRecycling[0..4]","Materials","M","3-7","Main",">=0","per material"},
            {"CEDWasteToLandfill[0..4]","Materials","N","3-7","Main",">=0","per material"},
            {"priceVirginPerMat[0..4]","Materials","O","3-7","Main",">0 SGD/t","per material"},
            {"priceSecondaryPerMat[0..4]","Materials","P","3-7","Main",">0 SGD/t","per material"},
            {"costLandfillPerMat[0..4]","Materials","Q","3-7","Main",">=0 SGD/t","per material"},
            {"pricePaidToProvider[0..4]","Materials","V","3-7","Main","any SGD/t","per material"},
            {"processingEffPerMat[0]","recycling_and processingfactors","C","5","Receiver_Plastic","(0,1]",""},
            {"processingEffPerMat[1]","recycling_and processingfactors","C","7","Receiver_Paper","(0,1]",""},
            {"processingEffPerMat[2]","recycling_and processingfactors","C","9","Receiver_Ferrous","(0,1]",""},
            {"processingEffPerMat[3]","recycling_and processingfactors","C","11","Receiver_Textile","(0,1]",""},
            {"processingEffPerMat[4]","recycling_and processingfactors","C","13","Receiver_NonFerrous","(0,1]",""},
            {"totalStorageCapacity","Intermediate","B","3","Intermediate",">0 t",""},
            {"tier1Pct","Intermediate","B","4","Intermediate","(0,1)",""},
            {"capexPerStorageUnit","Intermediate","B","7","Intermediate",">0 SGD/t",""},
            {"opexPerStorageUnitPerMonth","Intermediate","B","8","Intermediate",">=0 SGD/(t*mo)",""},
            {"salvageValuePercent","Intermediate","B","9","Intermediate","[0,1]",""},
            {"discountRate","Intermediate","B","10","Intermediate","(0,0.5)",""},
            {"truckVelocity_kmh","TruckFleet","A","3","GarbageTruck",">0 km/h","Phase 2 global"},
            {"loadingTime_h","TruckFleet","B","3","GarbageTruck",">=0 h","Phase 2 global"},
            {"unloadingTime_h","TruckFleet","C","3","GarbageTruck",">=0 h","Phase 2 global"},
            {"truckCap[PLASTIC..NONFERROUS]","TruckFleet","D-H","3","GarbageTruck",">0 t","Phase 2 global"},
            {"jollyTruckCount","TruckFleet","I","3","Intermediate",">=1","Phase 2: intermediate.truckCount"},
            {"jollyPremiumFactor","TruckFleet","J","3","Intermediate",">=1.0","Phase 2 global"},
            {"truckCapex_SGD","TruckFleet","K","3","GarbageTruck",">=0 SGD","Phase 2 global"},
            {"truckCount (x66)","Companies_Listing","I","2-67","Provider",">=1","Phase 2: per-provider col 9"},
            {"intermediateLat","Companies_Listing","E","73","Intermediate","GPS coord",""},
            {"intermediateLon","Companies_Listing","F","73","Intermediate","GPS coord",""},
            {"endOfLifeLat","derived","=intermediateLat","73","EndOfLife","= intermediateLat (Phase 1)","CE3.0 Phase 1: endOfLife ≡ BIWASE"},
            {"endOfLifeLon","derived","=intermediateLon","73","EndOfLife","= intermediateLon (Phase 1)","CE3.0 Phase 1: endOfLife ≡ BIWASE"},
            {"providerLat (x66)","Companies_Listing","E","2-67","Provider","GPS coord","per provider"},
            {"providerLon (x66)","Companies_Listing","F","2-67","Provider","GPS coord","per provider"},
            {"avgSupplyFromExcel (x66)","Companies_Listing","G","2-67","Provider",">0 t/week","per provider"},
            {"supplyVariability (x66)","Companies_Listing","H","2-67","Provider","(0,1]","per provider"},
            {"receiverLat (x5)","Companies_Listing","E","68-72","Receiver","GPS coord","per receiver"},
            {"receiverLon (x5)","Companies_Listing","F","68-72","Receiver","GPS coord","per receiver"},
            {"avgDemandFromExcel (x5)","Companies_Listing","G","68-72","Receiver",">0 t/week","per receiver"},
            {"demandVariability (x5)","Companies_Listing","H","68-72","Receiver","(0,1]","per receiver"},
        };

        for (String[] row : connectionMap) {
            org.apache.poi.xssf.usermodel.XSSFRow mRow = mapSheet.createRow(mapRow++);
            for (int c = 0; c < row.length; c++)
                mRow.createCell(c).setCellValue(row[c]);
        }

        // ── Sheet 4: TripLog ────────────────────────────────────────────────────────────────────
        org.apache.poi.xssf.usermodel.XSSFDataFormat tlFmt = wb.createDataFormat();
        org.apache.poi.xssf.usermodel.XSSFCellStyle numStyle = wb.createCellStyle();
        numStyle.setDataFormat(tlFmt.getFormat("0.000"));
        org.apache.poi.xssf.usermodel.XSSFCellStyle dayStyle = wb.createCellStyle();
        dayStyle.setDataFormat(tlFmt.getFormat("0.00"));

        org.apache.poi.xssf.usermodel.XSSFSheet tripLogSheet = wb.createSheet("TripLog");
        int[] tlColW = {2000,2000,2800,2500,6000,5000,3500,2500,4000,4000};
        String[] tlHdrs = {"SimDay","TruckID","Role","ProvIdx","ProviderName","Material",
                           "Payload_t","TripNum","CumulMass_t","TransitTime_d"};
        for (int c = 0; c < tlColW.length; c++) tripLogSheet.setColumnWidth(c, tlColW[c]);
        org.apache.poi.xssf.usermodel.XSSFRow tlHdrRow = tripLogSheet.createRow(0);
        for (int c = 0; c < tlHdrs.length; c++) {
            org.apache.poi.xssf.usermodel.XSSFCell tlC = tlHdrRow.createCell(c);
            tlC.setCellValue(tlHdrs[c]); tlC.setCellStyle(hdrStyle);
        }
        int tlRow = 1;
        for (Object[] entry : truckLog) {
            org.apache.poi.xssf.usermodel.XSSFRow tlR = tripLogSheet.createRow(tlRow++);
            tlR.createCell(0).setCellValue(((Number)entry[0]).doubleValue());
            tlR.createCell(1).setCellValue(((Number)entry[1]).intValue());
            tlR.createCell(2).setCellValue((String)entry[2]);
            tlR.createCell(3).setCellValue(((Number)entry[3]).intValue());
            tlR.createCell(4).setCellValue((String)entry[4]);
            tlR.createCell(5).setCellValue((String)entry[5]);
            org.apache.poi.xssf.usermodel.XSSFCell tlP = tlR.createCell(6);
            tlP.setCellValue(((Number)entry[6]).doubleValue());
            org.apache.poi.xssf.usermodel.XSSFCellStyle ns6 = wb.createCellStyle(); ns6.cloneStyleFrom(numStyle); tlP.setCellStyle(ns6);
            tlR.createCell(7).setCellValue(((Number)entry[7]).intValue());
            org.apache.poi.xssf.usermodel.XSSFCell tlCm = tlR.createCell(8);
            tlCm.setCellValue(((Number)entry[8]).doubleValue());
            org.apache.poi.xssf.usermodel.XSSFCellStyle ns8 = wb.createCellStyle(); ns8.cloneStyleFrom(numStyle); tlCm.setCellStyle(ns8);
            org.apache.poi.xssf.usermodel.XSSFCell tlTt = tlR.createCell(9);
            tlTt.setCellValue(((Number)entry[9]).doubleValue());
            org.apache.poi.xssf.usermodel.XSSFCellStyle ns9 = wb.createCellStyle(); ns9.cloneStyleFrom(numStyle); tlTt.setCellStyle(ns9);
        }
        tripLogSheet.createFreezePane(0, 1);

        // ── Sheet 5: TruckSummary ────────────────────────────────────────────────────────────
        org.apache.poi.xssf.usermodel.XSSFSheet truckSumSheet = wb.createSheet("TruckSummary");
        truckSumSheet.setColumnWidth(0,2000); truckSumSheet.setColumnWidth(1,2800);
        truckSumSheet.setColumnWidth(2,2500); truckSumSheet.setColumnWidth(3,6000);
        truckSumSheet.setColumnWidth(4,5000); truckSumSheet.setColumnWidth(5,3500);
        truckSumSheet.setColumnWidth(6,4000);
        String[] tsHdrs = {"TruckID","Role","ProvIdx","ProviderName","Material","Trips","TotalMass_t"};
        org.apache.poi.xssf.usermodel.XSSFRow tsHdrRow = truckSumSheet.createRow(0);
        for (int c = 0; c < tsHdrs.length; c++) {
            org.apache.poi.xssf.usermodel.XSSFCell tsC = tsHdrRow.createCell(c);
            tsC.setCellValue(tsHdrs[c]); tsC.setCellStyle(hdrStyle);
        }
        int tsRow = 1;
        for (int i = 0; i < garbageTrucks.size(); i++) {
            GarbageTruck gt = garbageTrucks.get(i);
            String tsRole = gt.isJolly ? "jolly" : ("dedicated#" + gt.myProviderIndex);
            String tsProvName = "—"; String tsMat = "mixed";
            if (!gt.isJolly && gt.myProviderIndex >= 0 && gt.myProviderIndex < providers.size()) {
                Provider tsp = (Provider) providers.get(gt.myProviderIndex);
                tsProvName = tsp.companyName; tsMat = tsp.myMaterial.toString();
            }
            org.apache.poi.xssf.usermodel.XSSFRow tsr = truckSumSheet.createRow(tsRow++);
            tsr.createCell(0).setCellValue(gt.truckIndex);
            tsr.createCell(1).setCellValue(tsRole);
            tsr.createCell(2).setCellValue(gt.myProviderIndex);
            tsr.createCell(3).setCellValue(tsProvName);
            tsr.createCell(4).setCellValue(tsMat);
            tsr.createCell(5).setCellValue(gt.tripsCompleted);
            org.apache.poi.xssf.usermodel.XSSFCell tmc = tsr.createCell(6); tmc.setCellValue(gt.totalMassCarried);
            org.apache.poi.xssf.usermodel.XSSFCellStyle tsNs = wb.createCellStyle(); tsNs.cloneStyleFrom(numStyle); tmc.setCellStyle(tsNs);
        }
        truckSumSheet.createFreezePane(0, 1);

        // ── Write file ────────────────────────────────────────────────────────
        try (java.io.FileOutputStream fos = new java.io.FileOutputStream(outPath)) {
            wb.write(fos);
        }
        wb.close();
        traceln("[CE3 Validation] Report (Summary+Errors+ConnMap+TripLog+TruckSummary) saved: " + outPath
            + " | " + truckLog.size() + " trip records | " + garbageTrucks.size() + " trucks");

    } catch (Exception ex) {
        traceln("[CE3 Validation] ERROR writing report: " + ex.getMessage());
        ex.printStackTrace();
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// TRUCK MOVEMENT LOG — CE 3.0 / 22MARZ
// Each completed trip is appended by GarbageTruck.home.EntryAction.
// Columns: SimDay | TruckID | Role | ProvIdx | ProviderName | Material
//          | Payload_t | TripNum | CumulMass_t | TransitTime_days
// ═══════════════════════════════════════════════════════════════════════════════
java.util.ArrayList<Object[]> truckLog = new java.util.ArrayList<>();

]]></AdditionalClassCode>
			<StartupCode><![CDATA[// ═══ CE 3.0 STARTUP (22MARZ): Read from 22MARZ.xlsx ════════════════════════
traceln(">>> CE3.0 STARTUP 22MARZ: onStartup() entered");

// ─── 1. Read per-material arrays from Materials sheet ────────────────────────
// Materials must be read FIRST so LCA arrays and prices are loaded before
// any CAPEX or financial initialisation that depends on them.
// Sheet structure (1-indexed AnyLogic rows):
//   R1=disclaimer, R2=headers, R3=PLASTIC_SCRAP, R4=PAPER_WASTE,
//   R5=FERROUS_METAL, R6=TEXTILE_WASTE, R7=NON_FERROUS_METAL
// Col R (RecyclingPlantCost_SGD) removed — Receivers are processing agents only;
// CAPEX is exclusively an Intermediate concern.
// After col R removal, PricePaidToProvider moves from col W to col V (index 22).
for (int m = 0; m < 5; m++) {
    int row = m + 3;  // 1-indexed: R3..R7
    traceln("CE3.0 22MARZ: Materials m=" + m + " row=" + row);
    conversionEffPerMat[m]   = Input_data.getCellNumericValue("Materials", row,  2); // Col B
    GWPVirginPerKg[m]        = Input_data.getCellNumericValue("Materials", row,  3); // Col C
    GWPWasteToRecycling[m]   = Input_data.getCellNumericValue("Materials", row,  4); // Col D
    GWPWasteToLandfill[m]    = Input_data.getCellNumericValue("Materials", row,  5); // Col E
    HTPVirginPerKg[m]        = Input_data.getCellNumericValue("Materials", row,  6); // Col F
    HTPWasteToRecycling[m]   = Input_data.getCellNumericValue("Materials", row,  7); // Col G
    HTPWasteToLandfill[m]    = Input_data.getCellNumericValue("Materials", row,  8); // Col H
    LUPVirginPerKg[m]        = Input_data.getCellNumericValue("Materials", row,  9); // Col I
    LUPWasteToRecycling[m]   = Input_data.getCellNumericValue("Materials", row, 10); // Col J
    LUPWasteToLandfill[m]    = Input_data.getCellNumericValue("Materials", row, 11); // Col K
    CEDVirginPerKg[m]        = Input_data.getCellNumericValue("Materials", row, 12); // Col L
    CEDWasteToRecycling[m]   = Input_data.getCellNumericValue("Materials", row, 13); // Col M
    CEDWasteToLandfill[m]    = Input_data.getCellNumericValue("Materials", row, 14); // Col N
    priceVirginPerMat[m]     = Input_data.getCellNumericValue("Materials", row, 15); // Col O — virgin purchase price
    priceSecondaryPerMat[m]  = Input_data.getCellNumericValue("Materials", row, 16); // Col P — recycled/secondary sale price
    costLandfillPerMat[m]    = Input_data.getCellNumericValue("Materials", row, 17); // Col Q — landfill disposal cost
    pricePaidToProvider[m]   = Input_data.getCellNumericValue("Materials", row, 22); // Col V — payment to/from provider
    traceln("  m=" + m + " convEff=" + conversionEffPerMat[m]
        + " priceV=" + priceVirginPerMat[m] + " priceSec=" + priceSecondaryPerMat[m]
        + " costLF=" + costLandfillPerMat[m] + " provPay=" + pricePaidToProvider[m]);
}

// processingEffPerMat: Receiver production efficiency from recycling_and processingfactors col C
processingEffPerMat[0] = Input_data.getCellNumericValue("recycling_and processingfactors", 5,  3);
processingEffPerMat[1] = Input_data.getCellNumericValue("recycling_and processingfactors", 7,  3);
processingEffPerMat[2] = Input_data.getCellNumericValue("recycling_and processingfactors", 9,  3);
processingEffPerMat[3] = Input_data.getCellNumericValue("recycling_and processingfactors", 11, 3);
processingEffPerMat[4] = Input_data.getCellNumericValue("recycling_and processingfactors", 13, 3);
traceln("processingEffPerMat: " + java.util.Arrays.toString(processingEffPerMat));
traceln("CE3.0 22MARZ: Per-material arrays loaded.");

// ─── 2. Read Intermediate parameters from Intermediate sheet ─────────────────
// Intermediate sheet structure (1-indexed AnyLogic rows):
//   R1=disclaimer, R2=headers
//   R3=StorageCapacity_total, R4=Tier1_GuaranteedPct, R5=Tier2_FlexiblePct,
//   R6=ProcessingRate_tDay
//   R7=capexPerStorageUnit
//   R8=opexPerStorageUnitPerMonth
//   R9=salvageValuePercent
//   R10=discountRate
//   Note: priceSecondaryPerMat[] is now per-material from Materials sheet col P (not from Intermediate)
double intTotalStorage     = Input_data.getCellNumericValue("Intermediate", 3, 2);  // 5000 t
double tier1Pct            = Input_data.getCellNumericValue("Intermediate", 4, 2);  // 0.12
capexPerStorageUnit        = Input_data.getCellNumericValue("Intermediate", 7, 2);  // 100 SGD/t
opexPerStorageUnitPerMonth = Input_data.getCellNumericValue("Intermediate", 8, 2);  // 2 SGD/(t*month)
salvageValuePercent        = Input_data.getCellNumericValue("Intermediate", 9, 2);  // 0.10
discountRate               = Input_data.getCellNumericValue("Intermediate", 10, 2); // 0.08  (R10)
// investedStorageCapacity mirrors the Intermediate sheet StorageCapacity_total
investedStorageCapacity    = intTotalStorage;

// ─── 3. Read Intermediate location from Companies_Listing ───────────────────
// Row 88 = Intermediate agent; Col5=Latitude, Col6=Longitude
// (Shifted from row 89 after Lotteria deletion)
intermediateLat = Input_data.getCellNumericValue("Companies_Listing", 73, 5);
intermediateLon = Input_data.getCellNumericValue("Companies_Listing", 73, 6);

// ─── 4. EndOfLife = Intermediate (BIWASE) — geographic unification ──────────
// CE3.0 Phase 1 (2026-03-26): endOfLife IS BIWASE. Both IS and non-IS waste
// go to the same physical location. Removes the artificial distance gap between
// the IS hub and the former hardcoded "landfill" coordinates.
// Old hardcoded values (BIWASE ETS Ben Cat): 11.085°N, 106.59°E — superseded.
endOfLifeLat = intermediateLat;  // CE3.0 Phase 1: landfill ≡ BIWASE (Companies_Listing row 73)
endOfLifeLon = intermediateLon;  // CE3.0 Phase 1: landfill ≡ BIWASE (Companies_Listing row 73)

// ─── 5. Read global truck fleet parameters from TruckFleet sheet ─────────────
// CE3.0 Phase 2 (2026-03-26): TruckFleet restructured to single global parameter row.
// R2=headers, R3=values. Old per-AgentType rows (providerTruckCount/intermTruckCount) removed.
// Per-provider truckCount now read from Companies_Listing col I (index 9) per row.
// JollyTruckCount (col I = index 9) assigned to intermediate.truckCount.
double truckVelocity_kmh             = Input_data.getCellNumericValue("TruckFleet", 3, 1);
double loadingTime_h                 = Input_data.getCellNumericValue("TruckFleet", 3, 2);
double unloadingTime_h               = Input_data.getCellNumericValue("TruckFleet", 3, 3);
double truckCapPLASTIC_t             = Input_data.getCellNumericValue("TruckFleet", 3, 4);
double truckCapPAPER_t               = Input_data.getCellNumericValue("TruckFleet", 3, 5);
double truckCapFERROUS_t             = Input_data.getCellNumericValue("TruckFleet", 3, 6);
double truckCapTEXTILE_t             = Input_data.getCellNumericValue("TruckFleet", 3, 7);
double truckCapNONFERROUS_t          = Input_data.getCellNumericValue("TruckFleet", 3, 8);
int    jollyTruckCount               = (int) Input_data.getCellNumericValue("TruckFleet", 3, 9);
double jollyPremiumFactor            = Input_data.getCellNumericValue("TruckFleet", 3, 10);
double truckCapex_SGD                = Input_data.getCellNumericValue("TruckFleet", 3, 11);
traceln("CE3.0 TruckFleet: velocity=" + truckVelocity_kmh + " km/h"
    + "  loading=" + loadingTime_h + "h  unloading=" + unloadingTime_h + "h");
traceln("  Capacity(t): PLASTIC=" + truckCapPLASTIC_t + " PAPER=" + truckCapPAPER_t
    + " FERROUS=" + truckCapFERROUS_t + " TEXTILE=" + truckCapTEXTILE_t
    + " NONFERROUS=" + truckCapNONFERROUS_t);
traceln("  Jolly: count=" + jollyTruckCount + " premiumFactor=" + jollyPremiumFactor
    + "  TruckCapex=" + truckCapex_SGD + " SGD");
// NOTE: truckVelocity_kmh, loadingTime_h, unloadingTime_h, truckCap*, jollyPremiumFactor,
// truckCapex_SGD are logged here. Full wiring to GarbageTruck agent properties is Phase 3.

// ─── 6. Initialize Providers from Companies_Listing (rows 2-67) ─────────────
// Col1=ID, Col2=CompanyName, Col3=AgentType, Col4=Material,
// Col5=Latitude, Col6=Longitude, Col7=AvgSupply_tWeek, Col8=SupplyVariability
// Col9=TruckCount (Phase 2), Col15=companyAddress (shifted by col I insertion)
// Providers are pure waste generators — no investment (CAPEX/OPEX) assigned here.
for (int i = 0; i < providers.size(); i++) {
    Provider p    = providers.get(i);
    int row       = i + 2;
    p.providerLat        = Input_data.getCellNumericValue("Companies_Listing", row, 5);
    p.providerLon        = Input_data.getCellNumericValue("Companies_Listing", row, 6);
    String matStr        = Input_data.getCellStringValue("Companies_Listing",  row, 4);
    p.avgSupplyFromExcel = Input_data.getCellNumericValue("Companies_Listing", row, 7);
    p.supplyVariability  = Input_data.getCellNumericValue("Companies_Listing", row, 8); // col H
    p.truckCount         = (int) Input_data.getCellNumericValue("Companies_Listing", row, 9); // CE3.0 Phase 2: col I
    if      (matStr.contains("PLASTIC"))                              p.myMaterial = MaterialType.PLASTIC_SCRAP;
    else if (matStr.contains("PAPER"))                                p.myMaterial = MaterialType.PAPER_WASTE;
    else if (matStr.contains("FERROUS") && !matStr.contains("NON"))  p.myMaterial = MaterialType.FERROUS_METAL;
    else if (matStr.contains("TEXTILE"))                              p.myMaterial = MaterialType.TEXTILE_WASTE;
    else if (matStr.contains("NON"))                                  p.myMaterial = MaterialType.NON_FERROUS_METAL;
    else                                                              p.myMaterial = MaterialType.PLASTIC_SCRAP;
    p.providerIndex  = i;
    p.companyName    = Input_data.getCellStringValue("Companies_Listing", row,  2);
    p.companyAddress = Input_data.getCellStringValue("Companies_Listing", row, 15); // CE3.0 Phase 2: col O (shifted by TruckCount insertion)
    p.jumpTo(p.providerLat, p.providerLon);
    traceln("Provider[" + i + "] " + matStr
        + " lat=" + String.format("%.4f", p.providerLat)
        + " lon=" + String.format("%.4f", p.providerLon)
        + " supply=" + String.format("%.2f", p.avgSupplyFromExcel) + " t/week");
}

// ─── 6b. Reposition dedicated GarbageTruck agents to their provider's location ─
// CE3.0 Phase 3: trucks 0-65 are dedicated to providers 0-65.
// GarbageTruck startup placed all trucks at BIWASE (safe default).
// Now that providers are initialized, move each dedicated truck to its provider.
for (int i = 0; i < providers.size() && i < garbageTrucks.size(); i++) {
    GarbageTruck gt = garbageTrucks.get(i);
    if (!gt.isJolly) {
        Provider pp = providers.get(i);
        gt.jumpTo(pp.providerLat, pp.providerLon);
    }
}
traceln("CE3.0 Fleet: " + providers.size() + " dedicated trucks + "
    + (garbageTrucks.size() - providers.size()) + " jolly trucks = "
    + garbageTrucks.size() + " total");

// ─── 7. Initialize Receivers from Companies_Listing (rows 68-72) ────────────
// Row 68=Plastic, 69=Paper, 70=Ferrous, 71=Textile, 72=NonFerrous
// (Rows shifted −1 after Lotteria deletion from provider list)
// Receivers are processing agents (material transformation), NOT recycling plants.
// No CAPEX is assigned to Receiver agents.
for (int i = 0; i < receivers.size(); i++) {
    Receiver r    = receivers.get(i);
    int row       = 68 + i;  // CE3.0 fix 2026-03-25: receivers are at Excel rows 68-72, not 83-87
    double rLat   = Input_data.getCellNumericValue("Companies_Listing", row, 5);
    double rLon   = Input_data.getCellNumericValue("Companies_Listing", row, 6);
    String matStr = Input_data.getCellStringValue("Companies_Listing",  row, 4);
    if      (matStr.contains("PLASTIC"))                              r.myMaterial = MaterialType.PLASTIC_SCRAP;
    else if (matStr.contains("PAPER"))                                r.myMaterial = MaterialType.PAPER_WASTE;
    else if (matStr.contains("FERROUS") && !matStr.contains("NON"))  r.myMaterial = MaterialType.FERROUS_METAL;
    else if (matStr.contains("TEXTILE"))                              r.myMaterial = MaterialType.TEXTILE_WASTE;
    else if (matStr.contains("NON"))                                  r.myMaterial = MaterialType.NON_FERROUS_METAL;
    else                                                              r.myMaterial = MaterialType.PLASTIC_SCRAP;
    r.receiverLat = rLat;
    r.receiverLon = rLon;
    r.jumpTo(rLat, rLon);
    r.avgDemandFromExcel  = Input_data.getCellNumericValue("Companies_Listing", row, 7); // col G
    r.demandVariability   = Input_data.getCellNumericValue("Companies_Listing", row, 8); // col H
    r.processingEfficiency = processingEffPerMat[matIndex(r.myMaterial)];
    traceln("Receiver[" + i + "] " + matStr
        + " lat=" + String.format("%.4f", rLat)
        + " lon=" + String.format("%.4f", rLon));
}

// ─── 8. Initialize Intermediate agent ────────────────────────────────────────
// The Intermediate is the sole IS infrastructure agent carrying CAPEX and OPEX.
// CAPEX = total storage capacity x cost per tonne (both from Intermediate sheet).
// OPEX is computed monthly by the calculateOPEX cyclic event (variable-cost model).
intermediate.totalStorageCapacity = intTotalStorage;
intermediate.truckCount           = jollyTruckCount;  // CE3.0 Phase 2: jolly truck pool from TruckFleet col I
intermediate.intermediateLat      = intermediateLat;
intermediate.intermediateLon      = intermediateLon;
intermediate.jumpTo(intermediateLat, intermediateLon);

int nMat = MaterialType.values().length;
for (int m = 0; m < nMat; m++) {
    intermediate.tier1CapPerMat[m]         = intTotalStorage * tier1Pct;
    intermediate.currentStockPerMat[m]     = 0;
    intermediate.recyclingStoragePerMat[m] = 0;
}
// Tier 2: shared flexible pool = total minus sum of all Tier-1 allocations
intermediate.tier2SharedCapacity = intTotalStorage * (1.0 - tier1Pct * nMat);
if (intermediate.tier2SharedCapacity < 0) {
    traceln("WARNING: tier2SharedCapacity < 0 (tier1Pct * nMat > 1). Clamped to 0.");
    intermediate.tier2SharedCapacity = 0;
}

// CAPEX: Intermediate storage infrastructure only
double intCapex = intTotalStorage * capexPerStorageUnit;
intermediate.intermediateCapex  = intCapex;
intermediate.financialBalance  -= intCapex;
intermediate.totalCosts        += intCapex;

// ─── 9. Position EndOfLife on GIS map ────────────────────────────────────────
// CE3.0 Phase 2: EndOfLife agent eliminated — landfill function absorbed by Intermediate.
// landfill.jumpTo(endOfLifeLat, endOfLifeLon); // superseded

// ─── 10. Network-level CAPEX ─────────────────────────────────────────────────
totalCapex = intCapex;

traceln("CE3.0 22MARZ Startup complete.");
traceln("  Intermediate CAPEX : " + String.format("%.2f", intCapex) + " SGD"
    + "  (" + String.format("%.0f", intTotalStorage) + " t x "
    + String.format("%.2f", capexPerStorageUnit) + " SGD/t)");
traceln("  Providers: " + providers.size() + " | useIS=" + useIS);

// Excel connection validation
validateExcelConnections();
]]></StartupCode>
