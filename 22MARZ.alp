							<Value Class="CodeValue">
								<Code><![CDATA[// Stage 1: Waste Drying — ~20% of combustion emissions
double dryingMass_kg = WasteToBeBurned * 1000.0 * 0.20;
totalCO2EmittedKg += dryingMass_kg * emissionFactor_CO2_kgPerKg;
totalCOEmittedKg  += dryingMass_kg * emissionFactor_CO_kgPerKg;
totalNOxEmittedKg += dryingMass_kg * emissionFactor_NOx_kgPerKg;
traceln(String.format("[DRYING-COMPLETE] t=%.1f | mass_kg=%.1f | CO2+=%.3f kg",
    time(), dryingMass_kg, dryingMass_kg * emissionFactor_CO2_kgPerKg));]]></Code>
							</Value>
						</Parameter>
